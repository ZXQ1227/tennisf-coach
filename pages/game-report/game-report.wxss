/* ── Base ── */
.gr-page {
  min-height: 100vh;
  background: #0E231A;
  position: relative;
  box-sizing: border-box;
}

.gr-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.gr-spin {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(166, 255, 51, 0.2);
  border-top-color: #A6FF33;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg) } }

.gr-body {
  padding: 32rpx 32rpx 0;
}

/* ── Header ── */
.gr-header {
  text-align: center;
  padding: 24rpx 0 40rpx;
}

.gr-report-badge {
  display: inline-block;
  font-size: 24rpx;
  color: #A6FF33;
  border: 1.5rpx solid #A6FF33;
  border-radius: 20rpx;
  padding: 6rpx 20rpx;
  letter-spacing: 2rpx;
  margin-bottom: 28rpx;
}

.gr-venue {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 12rpx;
}

.gr-date {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.gr-tags {
  display: flex;
  gap: 12rpx;
  justify-content: center;
}

.gr-tag {
  font-size: 22rpx;
  color: rgba(166, 255, 51, 0.8);
  border: 1rpx solid rgba(166, 255, 51, 0.4);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

/* ── Score Card ── */
.gr-score-card {
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  margin-bottom: 24rpx;
}

.gr-score-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.gr-score-hd-txt {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
  letter-spacing: 1rpx;
}

.gr-sets-win {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 26rpx;
}

.gr-win-a, .gr-win-b {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.5);
}

.gr-win-hi {
  color: #A6FF33;
}

.gr-win-sep {
  font-size: 20rpx;
  color: rgba(255,255,255,0.3);
}

.gr-win-colon {
  font-size: 24rpx;
  color: rgba(255,255,255,0.3);
  margin: 0 2rpx;
}

.gr-score-main {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-bottom: 28rpx;
}

.gr-score-side {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.gr-player-name {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.gr-score-num {
  font-size: 88rpx;
  font-weight: 800;
  line-height: 1;
}

.gr-score-winner {
  color: #A6FF33;
}

.gr-score-loser {
  color: rgba(255,255,255,0.35);
}

.gr-colon {
  font-size: 56rpx;
  color: rgba(255,255,255,0.25);
  padding: 0 24rpx;
  margin-top: 24rpx;
}

/* Set breakdown */
.gr-sets-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.08);
}

.gr-set-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 80rpx;
}

.gr-set-score {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.75);
}

.gr-set-lbl {
  font-size: 20rpx;
  color: rgba(255,255,255,0.35);
}

/* ── Stats Row ── */
.gr-stats-row {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 20rpx;
  padding: 28rpx 0;
  margin-bottom: 24rpx;
}

.gr-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.gr-stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.gr-stat-lbl {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}

.gr-stat-div {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.1);
}

/* ── Players ── */
.gr-players-card,
.gr-moments-card {
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.gr-sec-lbl {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
  letter-spacing: 1rpx;
  margin-bottom: 20rpx;
}

.gr-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.gr-chip {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  background: rgba(166, 255, 51, 0.12);
  border: 1rpx solid rgba(166, 255, 51, 0.25);
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
}

/* ── Moments ── */
.gr-moment-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.gr-ms-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.gr-ms-icon {
  font-size: 28rpx;
}

.gr-ms-txt {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

/* ── Brand ── */
.gr-brand {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255,255,255,0.15);
  letter-spacing: 4rpx;
  font-weight: 600;
  padding: 32rpx 0 40rpx;
}

/* ── Buttons ── */
.gr-btns {
  display: flex;
  gap: 20rpx;
  padding-bottom: 32rpx;
}

.gr-btn-sec {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: rgba(255,255,255,0.7);
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 48rpx;
  padding: 28rpx 0;
}

.gr-btn-pri {
  flex: 1.4;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #0E231A;
  background: #A6FF33;
  border-radius: 48rpx;
  padding: 28rpx 0;
}
