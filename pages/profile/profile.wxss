.page { background: #F7F8FA; min-height: 100vh; }

/* ── 无档案引导 ── */
.setup-prompt-hero {
  background: linear-gradient(145deg, #071410 0%, #0E2319 55%, #071410 100%);
  padding: 64rpx 40rpx 56rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}


.hero-glow {
  position: absolute;
  width: 400rpx; height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(43,182,115,0.18) 0%, transparent 70%);
  top: -100rpx; right: -60rpx;
}

.prompt-avatar { font-size: 96rpx; position: relative; margin-bottom: 24rpx; }

.prompt-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  position: relative;
  margin-bottom: 14rpx;
  letter-spacing: -1rpx;
}

.prompt-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  position: relative;
  line-height: 1.6;
}

.prompt-body { padding: 36rpx 32rpx; }

.prompt-features {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.prompt-feature {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.feature-icon { font-size: 44rpx; }

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 4rpx;
}

.feature-desc { font-size: 24rpx; color: #AAAAAA; }

.create-btn {
  width: 100%;
  background: #2BB673;
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 34rpx;
  font-weight: 700;
  height: 100rpx;
  line-height: 100rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(43,182,115,0.4);
}

/* ── Hero 球员卡 ── */
.hero {
  background: linear-gradient(145deg, #071410 0%, #0E2319 55%, #071410 100%);
  padding: 56rpx 40rpx 44rpx;
  position: relative;
  overflow: hidden;
}

.hero-glow-tl {
  position: absolute; width: 480rpx; height: 480rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(43,182,115,0.2) 0%, transparent 68%);
  top: -160rpx; left: -100rpx;
}

.hero-glow-br {
  position: absolute; width: 360rpx; height: 360rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(166,255,51,0.10) 0%, transparent 68%);
  bottom: -100rpx; right: -80rpx;
}

.hero-content { position: relative; }

.hero-top {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

/* Avatar */
.hero-av-wrap { position: relative; flex-shrink: 0; }
.hero-av-img {
  width: 108rpx; height: 108rpx; border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.25);
  box-shadow: 0 0 28rpx rgba(43,182,115,0.35);
}
.hero-av-letter {
  width: 108rpx; height: 108rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; font-weight: 900; color: #FFFFFF;
  border: 3rpx solid rgba(255,255,255,0.2);
  box-shadow: 0 0 28rpx rgba(43,182,115,0.3);
}
.hero-av-dot {
  position: absolute; bottom: 4rpx; right: 4rpx;
  width: 20rpx; height: 20rpx; border-radius: 50%;
  background: #A6FF33; border: 3rpx solid #0E231A;
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%,100% { box-shadow: 0 0 4rpx #A6FF33; }
  50% { box-shadow: 0 0 14rpx #A6FF33; }
}

/* ID column */
.hero-id { flex: 1; }
.hero-name {
  font-size: 40rpx; font-weight: 800; color: #FFFFFF;
  letter-spacing: -0.5rpx; margin-bottom: 10rpx;
}
.hero-tags-row { display: flex; gap: 10rpx; flex-wrap: wrap; margin-bottom: 8rpx; }
.hero-tag-lvl {
  font-size: 22rpx; font-weight: 700;
  background: rgba(255,255,255,0.1); border: 1rpx solid rgba(255,255,255,0.15);
  padding: 5rpx 18rpx; border-radius: 100rpx;
}
.hero-tag-sty {
  font-size: 22rpx; color: rgba(255,255,255,0.55);
  background: rgba(255,255,255,0.07); border: 1rpx solid rgba(255,255,255,0.1);
  padding: 5rpx 18rpx; border-radius: 100rpx;
}

.edit-btn {
  background: rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.75);
  border-radius: 100rpx;
  font-size: 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 24rpx;
  border: none;
  flex-shrink: 0;
}

/* Bio */
.hero-bio {
  font-size: 26rpx; color: rgba(255,255,255,0.6);
  font-style: italic; line-height: 1.7;
  text-align: center; padding: 12rpx 0 16rpx;
}

/* Status row */
.hero-status-row {
  display: flex; align-items: center; justify-content: center;
  gap: 10rpx; margin-bottom: 24rpx;
}
.status-dot { width: 14rpx; height: 14rpx; border-radius: 50%; flex-shrink: 0; }
.status-on { background: #A6FF33; animation: pulse-dot 2s ease-in-out infinite; }
.status-off { background: rgba(255,255,255,0.25); }
.status-txt { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.status-court { font-size: 24rpx; color: rgba(255,255,255,0.4); }

/* Nums row */
.hero-nums-row {
  display: flex; align-items: center;
  background: rgba(255,255,255,0.07); border-radius: 24rpx;
  padding: 20rpx 0; margin-bottom: 20rpx;
}
.hero-num-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.hero-num-main { display: flex; align-items: baseline; gap: 4rpx; }
.hero-num-val { font-size: 48rpx; font-weight: 900; color: #FFFFFF; letter-spacing: -1rpx; line-height: 1; }
.hero-num-unit { font-size: 20rpx; color: rgba(255,255,255,0.5); }
.hero-num-lbl { font-size: 19rpx; color: rgba(255,255,255,0.38); }
.hero-num-sep { width: 1rpx; height: 44rpx; background: rgba(255,255,255,0.1); }

/* CTA */
.hero-cta {
  text-align: center;
  background: rgba(166,255,51,0.12); border: 1rpx solid rgba(166,255,51,0.35);
  color: #A6FF33; border-radius: 100rpx;
  font-size: 28rpx; font-weight: 700;
  padding: 18rpx 0; letter-spacing: 1rpx;
}

/* ── Body ── */
.body { padding: 28rpx 28rpx 48rpx; }

.card {
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.05);
  border: 1rpx solid #F0F0F0;
}

.card-title { font-size: 28rpx; font-weight: 700; color: #1A1A1A; margin-bottom: 28rpx; }
.card-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; }
.card-title-sub { font-size: 22rpx; color: #BBBBBB; }

.stats-grid { display: flex; flex-wrap: wrap; }
.stat-block { width: 50%; display: flex; flex-direction: column; gap: 6rpx; padding: 12rpx 0 24rpx; }
.stat-block:nth-child(odd) { padding-right: 24rpx; border-right: 1rpx solid #F5F5F5; }
.stat-block:nth-child(even) { padding-left: 24rpx; }
.stat-block:nth-child(1), .stat-block:nth-child(2) { border-bottom: 1rpx solid #F5F5F5; padding-bottom: 28rpx; }
.stat-block:nth-child(3), .stat-block:nth-child(4) { padding-top: 28rpx; }

.stat-big { font-size: 56rpx; font-weight: 900; color: #1A1A1A; letter-spacing: -2rpx; line-height: 1; }
.stat-dim { color: #CCCCCC; }
.stat-big-sm { font-size: 30rpx; font-weight: 700; color: #1A1A1A; line-height: 1.3; }
.stat-sub { font-size: 22rpx; color: #AAAAAA; }
.last-active { margin-top: 20rpx; font-size: 24rpx; color: #2BB673; font-weight: 500; padding-top: 20rpx; border-top: 1rpx solid #F5F5F5; }

/* ── 球搭子轻列表 ── */
.pl-list { display: flex; flex-direction: column; }
.pl-row { display: flex; align-items: center; gap: 20rpx; padding: 18rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.pl-row:last-child { border-bottom: none; padding-bottom: 0; }
.pl-av { width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 900; color: #FFFFFF; flex-shrink: 0; }
.pl-av-img { width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0; }
.pl-info { flex: 1; }
.pl-name-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 6rpx; }
.pl-name { font-size: 28rpx; font-weight: 700; color: #1A1A1A; }
.pl-chip { font-size: 20rpx; color: #888; background: #F5F5F5; border-radius: 100rpx; padding: 3rpx 14rpx; font-weight: 500; }
.pl-chip-strong { color: #2BB673; background: #E8F9F1; font-weight: 600; }
.pl-meta { font-size: 22rpx; color: #AAAAAA; }
.pl-invite { background: #F0FBF5; color: #2BB673; border: 1rpx solid rgba(43,182,115,0.3); font-size: 22rpx; font-weight: 700; padding: 10rpx 22rpx; border-radius: 100rpx; flex-shrink: 0; }

/* ── Weekly rhythm ── */
.weekly-card { }
.weekly-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28rpx; }
.weekly-streak-badge { font-size: 22rpx; font-weight: 700; color: #FF6B6B; background: #FFF5F5; border-radius: 100rpx; padding: 6rpx 18rpx; }
.weekly-grid { display: flex; justify-content: space-between; }
.weekly-day { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.weekly-day-name { font-size: 20rpx; color: #AAAAAA; }
.weekly-day-today { color: #2BB673; font-weight: 700; }
.weekly-ball-wrap { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.weekly-ball { width: 52rpx; height: 52rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.weekly-ball-on { background: #E8F9F1; border: 2rpx solid rgba(43,182,115,0.3); }
.weekly-ball-off { background: #F7F8FA; }
.weekly-ball-txt { font-size: 24rpx; }
.weekly-dur { font-size: 20rpx; color: #CCCCCC; }
.weekly-dur-on { color: #2BB673; font-weight: 600; }

.achievements-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.achievement-item { width: calc(33.33% - 12rpx); background: #F7F8FA; border-radius: 24rpx; padding: 24rpx 16rpx; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.achievement-locked { opacity: 0.3; }
.achievement-icon { font-size: 44rpx; }
.achievement-name { font-size: 22rpx; font-weight: 700; color: #1A1A1A; text-align: center; }
.achievement-desc { font-size: 18rpx; color: #AAAAAA; text-align: center; line-height: 1.4; }

/* ── 比赛回忆（轻列表）── */
.rl-list { display: flex; flex-direction: column; }
.rl-row { display: flex; flex-direction: column; padding: 20rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.rl-row:last-child { border-bottom: none; padding-bottom: 0; }
.rl-row-dim { opacity: 0.45; }
.rl-meta { font-size: 22rpx; color: #AAAAAA; margin-bottom: 6rpx; }
.rl-main { font-size: 28rpx; font-weight: 600; color: #1A1A1A; }
.rl-photo { font-size: 22rpx; color: #2BB673; margin-top: 6rpx; }

.empty-wrap { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; gap: 16rpx; }
.empty-emoji { font-size: 72rpx; }
.empty-text { font-size: 28rpx; color: #CCC; }


/* ── 置顶成就徽章 ── */
.hero-pinned { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 10rpx; }
.hero-pinned-badge {
  background: rgba(166,255,51,0.12);
  border: 1rpx solid rgba(166,255,51,0.35);
  color: #A6FF33;
  font-size: 18rpx;
  font-weight: 600;
  padding: 5rpx 14rpx;
  border-radius: 100rpx;
}

/* ── 热力图 ── */
.hm-wrap { padding: 8rpx 0 16rpx; }
.hm-grid { display: flex; flex-direction: row; align-items: flex-start; }
.hm-labels { display: flex; flex-direction: column; gap: 5rpx; flex-shrink: 0; width: 22rpx; margin-right: 8rpx; }
.hm-day-lbl { height: 28rpx; font-size: 16rpx; color: rgba(255,255,255,0.28); display: flex; align-items: center; }
.hm-scroll { flex: 1; }
.hm-weeks { display: inline-flex; gap: 5rpx; }
.hm-week { display: flex; flex-direction: column; gap: 5rpx; }
.hm-cell { width: 28rpx; height: 28rpx; border-radius: 6rpx; }
.hm-future { background: rgba(255,255,255,0.03); }
.hm-i0 { background: rgba(255,255,255,0.08); }
.hm-i1 { background: rgba(43,182,115,0.45); }
.hm-i2 { background: rgba(43,182,115,0.78); }
.hm-i3 { background: #A6FF33; }

/* ── 成就置顶样式 ── */
.achievement-pinned { border: 1.5rpx solid rgba(43,182,115,0.45) !important; background: #F0FBF5 !important; }
.achievement-pin-badge {
  font-size: 16rpx; color: #2BB673; background: rgba(43,182,115,0.1);
  padding: 3rpx 10rpx; border-radius: 100rpx; font-weight: 600; margin-top: 4rpx;
}

/* ── Sheet 通用 ── */
.sheet-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.58);
  z-index: 300;
  display: flex; align-items: flex-end;
}
.bottom-sheet {
  width: 100%;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 72vh;
  overflow-y: auto;
}
.sheet-handle { width: 80rpx; height: 8rpx; background: #E5E5E5; border-radius: 4rpx; margin: 0 auto 28rpx; }
.sheet-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; margin-bottom: 20rpx; }
.sheet-empty { font-size: 26rpx; color: #AAAAAA; padding: 40rpx 0; text-align: center; }

/* ── Day Sheet 球局条目 ── */
.sheet-game-item { display: flex; align-items: center; gap: 20rpx; padding: 20rpx 0; border-top: 1rpx solid #F5F5F5; }
.sgi-left { width: 20rpx; flex-shrink: 0; }
.sgi-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.sgi-content { flex: 1; }
.sgi-location { font-size: 28rpx; font-weight: 600; color: #1A1A1A; margin-bottom: 4rpx; }
.sgi-meta { font-size: 22rpx; color: #AAAAAA; }
.sgi-arrow { font-size: 32rpx; color: #DDDDDD; }

/* ── Achievement Sheet ── */
.achiev-detail { display: flex; flex-direction: column; align-items: center; padding: 20rpx 0 24rpx; }
.achiev-big-icon { font-size: 88rpx; margin-bottom: 20rpx; }
.achiev-detail-name { font-size: 38rpx; font-weight: 800; color: #1A1A1A; margin-bottom: 12rpx; }
.achiev-detail-desc { font-size: 26rpx; color: #888; margin-bottom: 36rpx; }
.achiev-actions { width: 100%; }
.achiev-pin-btn {
  width: 100%; text-align: center; padding: 24rpx; border-radius: 24rpx;
  font-size: 28rpx; font-weight: 600; background: #F7F8FA; color: #555;
  border: 1rpx solid #E5E5E5; box-sizing: border-box;
}
.achiev-pin-active { background: #E8F9F1; color: #2BB673; border-color: rgba(43,182,115,0.35); }
.achiev-locked-hint { font-size: 24rpx; color: #AAAAAA; text-align: center; }
