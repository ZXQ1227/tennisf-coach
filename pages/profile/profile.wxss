/* ════════════════════════════════════════════
   设计 Token
   背景基底: #121C17   卡片: #1A2820
   荧光绿:  #B2FF33   品牌绿: #2BB673
   ════════════════════════════════════════════ */

.page-dark { background: #121C17; min-height: 100vh; }

/* ── 通用间距 ── */
.section-gap { padding: 20rpx 24rpx 0; }
.body-dark   { padding: 20rpx 24rpx 48rpx; }
.section-hd  { display: flex; align-items: center; justify-content: space-between; }

/* ════════════════════════════════════════════
   无档案引导
   ════════════════════════════════════════════ */
.setup-prompt-hero {
  background: linear-gradient(145deg, #071410 0%, #0E2319 55%, #071410 100%);
  padding: 64rpx 40rpx 56rpx;
  position: relative; overflow: hidden;
  display: flex; flex-direction: column; align-items: center; text-align: center;
}
.prompt-avatar { font-size: 96rpx; margin-bottom: 24rpx; }
.prompt-title  { font-size: 44rpx; font-weight: 800; color: #FFFFFF; margin-bottom: 14rpx; }
.prompt-sub    { font-size: 26rpx; color: rgba(255,255,255,0.5); line-height: 1.6; }

.prompt-body { padding: 36rpx 32rpx; background: #121C17; }
.prompt-features { display: flex; flex-direction: column; gap: 20rpx; margin-bottom: 40rpx; }
.prompt-feature {
  display: flex; align-items: center; gap: 24rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 24rpx; padding: 24rpx 28rpx;
}
.feature-icon { font-size: 44rpx; }
.feature-name { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.85); display: block; margin-bottom: 4rpx; }
.feature-desc { font-size: 24rpx; color: rgba(255,255,255,0.4); }

.create-btn {
  width: 100%; background: #2BB673; color: #FFFFFF; border-radius: 100rpx;
  font-size: 34rpx; font-weight: 700; height: 100rpx; line-height: 100rpx;
  border: none; box-shadow: 0 12rpx 32rpx rgba(43,182,115,0.4);
}

/* ════════════════════════════════════════════
   HERO 球员卡
   ════════════════════════════════════════════ */
.hero-dark {
  background: linear-gradient(160deg, #0A1810 0%, #0E2319 55%, #071410 100%);
  padding: 52rpx 40rpx 24rpx;
  position: relative; overflow: hidden;
}

.hero-glow-tl {
  position: absolute; width: 520rpx; height: 520rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(43,182,115,0.22) 0%, transparent 68%);
  top: -180rpx; left: -120rpx; pointer-events: none;
}
.hero-glow-br {
  position: absolute; width: 380rpx; height: 380rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(178,255,51,0.12) 0%, transparent 68%);
  bottom: -120rpx; right: -80rpx; pointer-events: none;
}

.hero-content { position: relative; }

/* 头像区 */
.hero-top { display: flex; align-items: flex-start; gap: 24rpx; margin-bottom: 18rpx; }
.hero-av-wrap { position: relative; flex-shrink: 0; }

.hero-av-img {
  width: 110rpx; height: 110rpx; border-radius: 50%;
  border: 2.5rpx solid #B2FF33;
  box-shadow: 0 0 18rpx rgba(178,255,51,0.5), 0 0 40rpx rgba(178,255,51,0.2);
}
.hero-av-letter {
  width: 110rpx; height: 110rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; font-weight: 900; color: #FFFFFF;
  border: 2.5rpx solid #B2FF33;
  box-shadow: 0 0 18rpx rgba(178,255,51,0.5), 0 0 40rpx rgba(178,255,51,0.2);
}
.hero-av-dot {
  position: absolute; bottom: 5rpx; right: 5rpx;
  width: 20rpx; height: 20rpx; border-radius: 50%;
  background: #B2FF33; border: 3rpx solid #0A1810;
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%,100% { box-shadow: 0 0 4rpx #B2FF33; }
  50%      { box-shadow: 0 0 16rpx #B2FF33; }
}

/* ID 列 */
.hero-id    { flex: 1; }
.hero-name  { font-size: 40rpx; font-weight: 800; color: #FFFFFF; letter-spacing: -0.5rpx; margin-bottom: 10rpx; }
.hero-tags-row { display: flex; gap: 10rpx; flex-wrap: wrap; margin-bottom: 8rpx; }

.hero-tag-lvl {
  font-size: 22rpx; font-weight: 700;
  background: rgba(255,255,255,0.1); border: 1rpx solid rgba(255,255,255,0.15);
  padding: 5rpx 18rpx; border-radius: 100rpx;
}
.hero-tag-sty {
  font-size: 22rpx; color: rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.07); border: 1rpx solid rgba(255,255,255,0.1);
  padding: 5rpx 18rpx; border-radius: 100rpx;
}

/* 置顶成就 */
.hero-pinned { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 10rpx; }
.hero-pinned-badge {
  background: rgba(178,255,51,0.12); border: 1rpx solid rgba(178,255,51,0.3);
  color: #B2FF33; font-size: 18rpx; font-weight: 600;
  padding: 5rpx 14rpx; border-radius: 100rpx;
}

/* 编辑按钮（玻璃拟态）*/
.edit-btn-glass {
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.8);
  border-radius: 100rpx; font-size: 24rpx;
  height: 62rpx; line-height: 62rpx; padding: 0 26rpx;
  flex-shrink: 0;
}

/* Bio 格言 */
.hero-bio-wrap {
  display: flex; align-items: flex-start; justify-content: center;
  gap: 10rpx; padding: 8rpx 8rpx 14rpx;
}
.bio-quote-mark {
  font-size: 48rpx; color: rgba(178,255,51,0.35);
  font-style: italic; font-weight: 300; line-height: 1; flex-shrink: 0;
}
.bio-text {
  font-size: 24rpx; color: rgba(255,255,255,0.42);
  font-style: italic; font-weight: 300; line-height: 1.75;
  flex: 1; text-align: center; padding-top: 12rpx;
}

/* 状态行 */
.hero-status-row {
  display: flex; align-items: center; justify-content: flex-start;
  gap: 10rpx;
}
.status-dot  { width: 14rpx; height: 14rpx; border-radius: 50%; flex-shrink: 0; }
.status-on   { background: #B2FF33; animation: pulse-dot 2s ease-in-out infinite; }
.status-off  { background: rgba(255,255,255,0.22); }
.status-txt  { font-size: 24rpx; color: rgba(255,255,255,0.65); }
.status-court{ font-size: 24rpx; color: rgba(255,255,255,0.38); }

/* ── 数据统计面板（新拟态）── */
/* ── 技能掌握度模块 ── */
.skill-module {
  background: rgba(255,255,255,0.04);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 22rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.hero-data-row {
  display: flex; align-items: flex-start; gap: 16rpx;
}
.hero-stats-col {
  flex: 1; display: flex; flex-direction: column; gap: 6rpx;
}
.skill-divider {
  width: 1rpx; align-self: stretch;
  background: rgba(255,255,255,0.08); margin: 0 8rpx;
}
.hours-val  { font-size: 40rpx; font-weight: 900; color: #FFFFFF; letter-spacing: -1rpx; }
.hours-spacer { height: 20rpx; }
.hours-lbl  { font-size: 26rpx; color: rgba(255,255,255,0.38); }
.hours-change-row { margin-top: 14rpx; }
.hours-change { font-size: 22rpx; font-weight: 600; }
.stat-big  { font-size: 42rpx; font-weight: 900; color: #FFFFFF; letter-spacing: -1rpx; line-height: 1; }
.stat-unit { font-size: 18rpx; color: rgba(255,255,255,0.42); }
.stat-lbl  { font-size: 19rpx; color: rgba(255,255,255,0.32); }

.hero-radar-wrap {
  flex: 1;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 0 4rpx 0 0;
}
.hero-radar-canvas { width: 180px; height: 180px; display: block; }

/* ── 约球 CTA（荧光边框+外发光）── */
.cta-glow-btn {
  text-align: center;
  background: linear-gradient(135deg, #0D3020 0%, #1A3A28 100%);
  border: 1.5rpx solid #B2FF33;
  box-shadow: 0 0 20rpx rgba(178,255,51,0.32), 0 6rpx 24rpx rgba(0,0,0,0.5);
  color: #B2FF33; border-radius: 100rpx;
  font-size: 32rpx; font-weight: 700;
  padding: 24rpx 0; letter-spacing: 3rpx;
  transition: all 0.15s;
}
.cta-pressed {
  box-shadow: 0 0 8rpx rgba(178,255,51,0.15), inset 0 2rpx 8rpx rgba(0,0,0,0.4);
  transform: scale(0.98);
}
.cta-row { display: flex; gap: 20rpx; }
.cta-half { flex: 3; }
.cta-ai-half { flex: 2; }
.cta-ai-btn {
  text-align: center;
  background: linear-gradient(135deg, #1A2030 0%, #252A3A 100%);
  border: 1.5rpx solid rgba(178,178,255,0.6);
  box-shadow: 0 0 20rpx rgba(140,140,255,0.2), 0 6rpx 24rpx rgba(0,0,0,0.5);
  color: #C8C8FF; border-radius: 100rpx;
  font-size: 32rpx; font-weight: 700;
  padding: 24rpx 0; letter-spacing: 3rpx;
  transition: all 0.15s;
}

/* ════════════════════════════════════════════
   AI 技能分析卡
   ════════════════════════════════════════════ */
.ai-analysis-card {
  background: #1A2820;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.45);
}

/* 标题 */
.ai-card-hd { margin-bottom: 22rpx; }
.ai-card-title-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 8rpx; }
.ai-card-title { font-size: 28rpx; font-weight: 700; color: #FFFFFF; }
.ai-personality-chip {
  font-size: 20rpx; font-weight: 600; color: #B2FF33;
  background: rgba(178,255,51,0.1); border: 1rpx solid rgba(178,255,51,0.25);
  padding: 5rpx 18rpx; border-radius: 100rpx;
}
.ai-stage-txt { font-size: 22rpx; color: rgba(255,255,255,0.38); }

/* 教练点评气泡 */
.ai-bubble {
  display: flex; gap: 14rpx; align-items: flex-start;
  background: rgba(178,255,51,0.05);
  border: 1rpx solid rgba(178,255,51,0.14);
  border-radius: 20rpx; padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}
.ai-bubble-icon { font-size: 28rpx; flex-shrink: 0; margin-top: 2rpx; }
.ai-bubble-txt  {
  font-size: 24rpx; color: rgba(255,255,255,0.65); line-height: 1.8; flex: 1;
}

/* 雷达图 */

/* 训练重点 pill */
.focus-row  { display: flex; justify-content: center; }
.focus-pill {
  background: rgba(178,255,51,0.1);
  border: 1rpx solid rgba(178,255,51,0.28);
  border-radius: 100rpx; padding: 14rpx 32rpx;
}
.focus-pill-txt { font-size: 24rpx; color: #B2FF33; font-weight: 600; }

/* ════════════════════════════════════════════
   约球邀请 Banner
   ════════════════════════════════════════════ */
.invite-banner {
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(90deg, #1A3D2B 0%, #0E231A 100%);
  border-left: 5rpx solid #B2FF33;
  border-radius: 20rpx; padding: 24rpx 28rpx;
}
.invite-banner-txt { font-size: 28rpx; font-weight: 600; color: #B2FF33; }
.invite-banner-arr { font-size: 36rpx; color: rgba(178,255,51,0.6); }

/* ════════════════════════════════════════════
   暗色通用卡片
   ════════════════════════════════════════════ */
.dark-card {
  background: #1A2820;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.35);
}
.dark-card-title { font-size: 28rpx; font-weight: 700; color: #FFFFFF; margin-bottom: 24rpx; }
.dark-card-sub   { font-size: 22rpx; color: rgba(255,255,255,0.32); }

/* ── 本周节奏 ── */
.streak-tag {
  font-size: 22rpx; font-weight: 700; color: #FFFFFF;
  background: linear-gradient(90deg, #FF6B2B, #FF3B3B);
  border-radius: 100rpx; padding: 6rpx 18rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,80,0,0.35);
}

.weekly-grid { display: flex; justify-content: space-between; padding-top: 8rpx; }
.wd-col  { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.wd-name { font-size: 20rpx; color: rgba(255,255,255,0.3); }
.wd-today { color: #B2FF33; font-weight: 700; }

.wd-circle {
  width: 54rpx; height: 54rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.wd-off {
  border: 2rpx solid rgba(255,255,255,0.14);
  background: transparent;
}
.wd-on {
  background: linear-gradient(145deg, #2BB673, #B2FF33);
  box-shadow: 0 0 14rpx rgba(178,255,51,0.45), inset 0 1rpx 0 rgba(255,255,255,0.18);
}
.wd-ball    { font-size: 26rpx; }
.wd-dur     { font-size: 20rpx; color: rgba(255,255,255,0.22); }
.wd-dur-on  { color: #B2FF33; font-weight: 600; }

/* ── 球搭子（暗色）── */
.pl-list { display: flex; flex-direction: column; }
.pl-row  {
  display: flex; align-items: center; gap: 20rpx;
  padding: 18rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.pl-row:last-child { border-bottom: none; padding-bottom: 0; }
.pl-av {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 900; color: #FFFFFF; flex-shrink: 0;
}
.pl-av-img { width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0; }
.pl-info   { flex: 1; }
.pl-name-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 6rpx; }
.pl-name   { font-size: 28rpx; font-weight: 700; color: rgba(255,255,255,0.9); }
.pl-chip   {
  font-size: 20rpx; color: rgba(255,255,255,0.4);
  background: rgba(255,255,255,0.07); border-radius: 100rpx;
  padding: 3rpx 14rpx; font-weight: 500;
}
.pl-chip-strong { color: #2BB673; background: rgba(43,182,115,0.15); font-weight: 600; }
.pl-meta   { font-size: 22rpx; color: rgba(255,255,255,0.32); }
.pl-invite {
  background: rgba(43,182,115,0.14); color: #2BB673;
  border: 1rpx solid rgba(43,182,115,0.3);
  font-size: 22rpx; font-weight: 700;
  padding: 10rpx 22rpx; border-radius: 100rpx; flex-shrink: 0;
}

/* ── 成就（暗色）── */
.achievements-grid { display: flex; flex-wrap: wrap; gap: 14rpx; }
.achievement-item {
  width: calc(33.33% - 10rpx);
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.07);
  border-radius: 24rpx; padding: 24rpx 10rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.achiev-earned { background: rgba(43,182,115,0.07); border-color: rgba(43,182,115,0.2); }
.achiev-pinned { background: rgba(178,255,51,0.08) !important; border-color: rgba(178,255,51,0.28) !important; }
.achiev-locked { opacity: 0.22; }
.achievement-icon { font-size: 44rpx; }
.achievement-name { font-size: 22rpx; font-weight: 700; color: rgba(255,255,255,0.85); text-align: center; }
.achievement-desc { font-size: 18rpx; color: rgba(255,255,255,0.32); text-align: center; line-height: 1.4; }
.achievement-pin-badge {
  font-size: 16rpx; color: #B2FF33; background: rgba(178,255,51,0.12);
  padding: 3rpx 10rpx; border-radius: 100rpx; font-weight: 600; margin-top: 4rpx;
}

/* ── 比赛回忆（暗色）── */
.rl-list { display: flex; flex-direction: column; }
.rl-row  {
  display: flex; flex-direction: column;
  padding: 20rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.rl-row:last-child { border-bottom: none; padding-bottom: 0; }
.rl-dim  { opacity: 0.38; }
.rl-meta { font-size: 22rpx; color: rgba(255,255,255,0.3); margin-bottom: 6rpx; }
.rl-main { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.82); }
.rl-photo{ font-size: 22rpx; color: #2BB673; margin-top: 6rpx; }

/* 空状态 */
.empty-wrap { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; gap: 16rpx; }
.empty-emoji { font-size: 72rpx; }
.empty-text  { font-size: 28rpx; color: rgba(255,255,255,0.22); }

/* ════════════════════════════════════════════
   Sheet 通用（保持浅色，提供对比感）
   ════════════════════════════════════════════ */
.sheet-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.6); z-index: 300;
  display: flex; align-items: flex-end;
}
.bottom-sheet {
  width: 100%; background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 72vh; overflow-y: auto;
}
.sheet-handle { width: 80rpx; height: 8rpx; background: #E5E5E5; border-radius: 4rpx; margin: 0 auto 28rpx; }
.sheet-title  { font-size: 32rpx; font-weight: 700; color: #1A1A1A; margin-bottom: 20rpx; }
.sheet-empty  { font-size: 26rpx; color: #AAAAAA; padding: 40rpx 0; text-align: center; }

.sheet-game-item { display: flex; align-items: center; gap: 20rpx; padding: 20rpx 0; border-top: 1rpx solid #F5F5F5; }
.sgi-left    { width: 20rpx; flex-shrink: 0; }
.sgi-dot     { width: 16rpx; height: 16rpx; border-radius: 50%; }
.sgi-content { flex: 1; }
.sgi-location{ font-size: 28rpx; font-weight: 600; color: #1A1A1A; margin-bottom: 4rpx; }
.sgi-meta    { font-size: 22rpx; color: #AAAAAA; }
.sgi-arrow   { font-size: 32rpx; color: #DDDDDD; }

/* 留言 Sheet */
.note-textarea   { width: 100%; min-height: 120rpx; background: #F7F8FA; border-radius: 20rpx; padding: 24rpx; font-size: 28rpx; color: #1A1A1A; box-sizing: border-box; border: none; }
.note-char-count { font-size: 22rpx; color: #BBBBBB; display: block; text-align: right; margin: 10rpx 0 24rpx; }
.note-actions    { display: flex; gap: 16rpx; }
.note-clear      { flex: 1; text-align: center; padding: 20rpx; border-radius: 20rpx; font-size: 26rpx; color: #AAAAAA; background: #F7F8FA; border: 1rpx solid #E5E5E5; }
.note-submit     { flex: 2; text-align: center; padding: 20rpx; border-radius: 20rpx; font-size: 28rpx; font-weight: 700; color: #0E231A; background: #A6FF33; }

/* 约球邀请 Sheet */
.invite-item      { padding: 24rpx 0; border-top: 1rpx solid #F0F0F0; }
.invite-from-row  { display: flex; align-items: center; margin-bottom: 20rpx; }
.invite-from-name { font-size: 30rpx; font-weight: 700; color: #1A1A1A; }
.invite-from-label{ font-size: 28rpx; color: #555; }
.invite-actions   { display: flex; gap: 16rpx; }
.invite-ignore    { flex: 1; text-align: center; padding: 20rpx; border-radius: 20rpx; font-size: 26rpx; color: #AAAAAA; background: #F7F8FA; border: 1rpx solid #E5E5E5; }
.invite-accept    { flex: 2; text-align: center; padding: 20rpx; border-radius: 20rpx; font-size: 28rpx; font-weight: 700; color: #0E231A; background: #A6FF33; }

/* 成就 Sheet */
.achiev-detail      { display: flex; flex-direction: column; align-items: center; padding: 20rpx 0 24rpx; }
.achiev-big-icon    { font-size: 88rpx; margin-bottom: 20rpx; }
.achiev-detail-name { font-size: 38rpx; font-weight: 800; color: #1A1A1A; margin-bottom: 12rpx; }
.achiev-detail-desc { font-size: 26rpx; color: #888; margin-bottom: 36rpx; }
.achiev-actions     { width: 100%; }
.achiev-pin-btn {
  width: 100%; text-align: center; padding: 24rpx; border-radius: 24rpx;
  font-size: 28rpx; font-weight: 600; background: #F7F8FA; color: #555;
  border: 1rpx solid #E5E5E5; box-sizing: border-box;
}
.achiev-pin-active  { background: #E8F9F1; color: #2BB673; border-color: rgba(43,182,115,0.35); }
.achiev-locked-hint { font-size: 24rpx; color: #AAAAAA; text-align: center; }

/* ── 挥拍记录 ── */
.swing-src-tag { font-size: 22rpx; color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.08); padding: 6rpx 18rpx; border-radius: 20rpx; }
.swing-stat-row { display: flex; align-items: center; margin-bottom: 24rpx; }
.swing-stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.swing-count { font-size: 72rpx; font-weight: 200; color: #FFFFFF; font-variant-numeric: tabular-nums; line-height: 1; }
.swing-label { font-size: 24rpx; color: rgba(255,255,255,0.45); }
.swing-divider-v { width: 1rpx; height: 80rpx; background: rgba(255,255,255,0.1); }
.swing-ratio-wrap { display: flex; height: 8rpx; border-radius: 4rpx; overflow: hidden; margin-bottom: 12rpx; }
.swing-ratio-fh { background: #A6FF33; }
.swing-ratio-bh { background: rgba(166,255,51,0.3); }
.swing-ratio-labels { display: flex; justify-content: space-between; margin-bottom: 20rpx; }
.swing-ratio-txt { font-size: 22rpx; color: rgba(255,255,255,0.4); }
.swing-last { padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.08); }
.swing-last-txt { font-size: 24rpx; color: rgba(255,255,255,0.35); }
.partners-empty-guest { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 32rpx 0; }
.partners-empty-icon { font-size: 56rpx; }
.partners-empty-txt { font-size: 26rpx; color: rgba(255,255,255,0.35); }
.swing-empty { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 32rpx 0; }
.swing-empty-icon { font-size: 56rpx; }
.swing-empty-txt { font-size: 26rpx; color: rgba(255,255,255,0.35); text-align: center; line-height: 1.5; }
.swing-chart-canvas { width: 100%; height: 220px; display: block; margin-bottom: 8rpx; }
.swing-legend { display: flex; flex-wrap: wrap; gap: 24rpx 40rpx; padding-top: 20rpx; }
.swing-leg-item { display: flex; align-items: center; gap: 12rpx; }
.swing-leg-dot { width: 18rpx; height: 18rpx; border-radius: 50%; flex-shrink: 0; }
.swing-leg-lbl { font-size: 24rpx; color: rgba(255,255,255,0.55); }
.swing-leg-val { font-size: 30rpx; font-weight: 700; color: #FFFFFF; }

/* ════════════════════════════════════════════
   新首页布局
   ════════════════════════════════════════════ */
.home-page { background: #121C17; min-height: 100vh; }

/* 顶部导航 */
/* ── Hero Section ── */
.hero-section {
  position: relative;
  background: linear-gradient(180deg, #03150F 0%, #041E15 50%, #08140F 100%);
  padding-left: 32rpx; padding-right: 32rpx; padding-bottom: 28rpx;
  overflow: hidden;
}
.brand-logo {
  display: flex; align-items: baseline; margin-bottom: 24rpx;
}
.brand-tennis {
  font-family: 'Montserrat', -apple-system, sans-serif;
  font-size: 52rpx; font-weight: 800; font-style: italic;
  letter-spacing: -1px; color: #FFFFFF;
}
.brand-f {
  font-family: 'Montserrat', -apple-system, sans-serif;
  font-size: 52rpx; font-weight: 800; font-style: italic;
  letter-spacing: -1px; color: #CFFF3D;
}

/* 问候区 */
.home-greeting-wrap {
  display: flex; align-items: center; gap: 24rpx;
}
.greeting-hi {
  font-size: 56rpx; font-weight: 900; color: #FFFFFF;
  letter-spacing: -1rpx;
  display: flex; align-items: center; gap: 12rpx;
}
.greeting-edit-icon {
  font-size: 32rpx; font-weight: 400; color: rgba(255,255,255,0.45);
  line-height: 1; transform: scaleX(-1);
}

/* 头像 */
.home-av-wrap { position: relative; }
.home-av-img {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  border: 2rpx solid #B2FF33;
}
.home-av-letter {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 900; color: #FFFFFF;
  border: 2rpx solid #B2FF33;
}
.home-av-dot {
  position: absolute; bottom: 2rpx; right: 2rpx;
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: #B2FF33; border: 2rpx solid #121C17;
}

/* ── 运动轨迹（旋转容器，右上→左下） ── */
.streak-bg {
  position: absolute;
  right: -60rpx; top: -10rpx;
  width: 580rpx; height: 320rpx;
  transform: rotate(22deg);
  transform-origin: 100% 0%;
  pointer-events: none;
}
.streak {
  position: absolute;
  height: 2rpx; border-radius: 999rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(194,255,61,0.15) 100%);
}
.s1 { width: 460rpx; right: 0; top: 48rpx; }
.s2 { width: 360rpx; right: 0; top: 76rpx; opacity: .7; }
.s3 { width: 240rpx; right: 0; top: 102rpx; opacity: .45; }

/* ── 粒子 ── */
.p {
  position: absolute;
  width: 4rpx; height: 4rpx;
  background: #CFFF3D; border-radius: 50%;
}
.p1 { right: 100rpx; top: 28rpx;  opacity: .15; }
.p2 { right: 190rpx; top: 72rpx;  opacity: .12; }
.p3 { right: 68rpx;  top: 110rpx; opacity: .18; }
.p4 { right: 250rpx; top: 44rpx;  opacity: .10; }
.p5 { right: 148rpx; top: 148rpx; opacity: .13; }
.p6 { right: 320rpx; top: 90rpx;  opacity: .15; }

/* 数据行 */
.home-stats-row {
  display: flex; align-items: center;
  padding: 0 24rpx 32rpx;
}
.home-stat { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.home-stat-val { font-size: 48rpx; font-weight: 900; color: #FFFFFF; line-height: 1; }
.stat-unit { font-size: 24rpx; font-weight: 500; color: rgba(255,255,255,0.55); }
.home-stat-tags { display: flex; gap: 6rpx; flex-wrap: wrap; justify-content: center; }
.stat-ntrp-tag {
  font-size: 20rpx; font-weight: 600; color: #B2FF33;
  background: rgba(178,255,51,0.12); border-radius: 100rpx;
  padding: 4rpx 14rpx;
}
.stat-style-tag {
  font-size: 20rpx; color: rgba(255,255,255,0.45);
  background: rgba(255,255,255,0.08); border-radius: 100rpx;
  padding: 4rpx 14rpx;
}
.home-stat-lbl { font-size: 22rpx; color: rgba(255,255,255,0.4); }
.stat-sep {
  width: 1rpx; height: 60rpx;
  background: rgba(255,255,255,0.1);
  margin: 0 8rpx;
}

/* 通用卡片 */
.home-card {
  background: #1A2820;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  padding: 32rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.35);
}
/* ── 未登录引导卡 ── */
.guest-card { padding: 0; overflow: hidden; }
.guest-card-inner {
  display: flex; flex-direction: column; align-items: center;
  padding: 52rpx 40rpx;
  background: linear-gradient(135deg, rgba(43,182,115,0.12), rgba(166,255,51,0.06));
}
.guest-card-icon { font-size: 64rpx; margin-bottom: 20rpx; }
.guest-card-title { font-size: 32rpx; font-weight: 700; color: #FFFFFF; margin-bottom: 12rpx; }
.guest-card-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 40rpx; }
.guest-login-btn {
  background: #2BB673; color: #FFFFFF;
  font-size: 28rpx; font-weight: 700;
  padding: 20rpx 60rpx; border-radius: 100rpx;
}
.home-av-guest { background: rgba(255,255,255,0.12) !important; color: rgba(255,255,255,0.4); }
.greeting-guest { font-size: 28rpx; color: rgba(255,255,255,0.6); font-weight: 400; }

.home-card-hd {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 24rpx;
}
.home-card-title-wrap { display: flex; align-items: center; gap: 10rpx; }
.home-card-title { font-size: 28rpx; font-weight: 700; color: #FFFFFF; }
.home-card-info-icon { font-size: 24rpx; color: rgba(255,255,255,0.35); }
.home-card-more { font-size: 24rpx; color: rgba(255,255,255,0.4); }
.home-card-sub-info { font-size: 22rpx; color: rgba(255,255,255,0.35); background: rgba(255,255,255,0.07); padding: 4rpx 16rpx; border-radius: 20rpx; }

/* 球员档案卡 */
.profile-card-body {
  display: flex; align-items: stretch; gap: 56rpx;
}
.home-radar-canvas { width: 180px; height: 180px; display: block; flex-shrink: 0; }
.radar-offscreen { position: absolute; left: -9999px; top: -9999px; }
.home-radar-placeholder { width: 180px; height: 180px; flex-shrink: 0; }
.profile-insight {
  flex: 1; display: flex; flex-direction: column; gap: 8rpx; padding-top: 16rpx;
}
.insight-line {
  font-size: 24rpx; color: rgba(255,255,255,0.75); line-height: 1.6; display: block;
}
.insight-dim { color: rgba(255,255,255,0.4); }
.skill-report-btn {
  margin-top: auto;
  align-self: flex-start;
  display: flex; align-items: center; gap: 10rpx;
  background: rgba(8,18,12,0.6);
  border: 1rpx solid rgba(178,255,51,0.28);
  border-radius: 100rpx; padding: 12rpx 24rpx;
}
.skill-report-icon { font-size: 24rpx; }
.skill-report-txt { font-size: 22rpx; color: rgba(178,255,51,0.75); font-weight: 600; letter-spacing: 0.5rpx; }

/* ── CTA 入口行 ── */
.cta-row {
  display: flex; gap: 16rpx; padding: 0 24rpx 20rpx;
}

/* 开始训练卡 */
.cta-card-training {
  flex: 1;
  background: #0C1A10;
  border: 2rpx solid rgba(43,182,115,0.75);
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  height: 220rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.55);
}
.cta-train-glow {
  position: absolute; right: -10rpx; top: -20rpx;
  width: 220rpx; height: 240rpx;
  background: radial-gradient(ellipse at 55% 45%, rgba(55,180,80,0.28) 0%, transparent 65%);
  pointer-events: none;
}
.cta-train-player {
  position: absolute; right: -20rpx; bottom: 0;
  width: 220rpx; height: 260rpx;
}
.cta-train-content {
  position: absolute; left: 28rpx; top: 28rpx;
}
.cta-train-title {
  font-size: 40rpx; font-weight: 900; color: #FFFFFF;
  letter-spacing: -1rpx; margin-bottom: 14rpx;
}
.cta-train-sub {
  display: block;
  font-size: 22rpx; color: rgba(255,255,255,0.55); line-height: 1.8;
}
.cta-train-arrow {
  position: absolute; right: 20rpx; bottom: 20rpx;
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #2BB673;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: #FFFFFF; font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(43,182,115,0.5);
}

/* 教练卡 */
.cta-card-coach {
  flex: 1;
  background: #0C1020;
  border: 1rpx solid rgba(136,153,238,0.2);
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  height: 220rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.55);
}
.cta-coach-glow {
  position: absolute; right: -10rpx; top: -20rpx;
  width: 220rpx; height: 240rpx;
  background: radial-gradient(ellipse at 50% 50%, rgba(80,100,230,0.35) 0%, rgba(60,80,200,0.12) 45%, transparent 70%);
  pointer-events: none;
}
.cta-coach-brain {
  position: absolute; right: 16rpx; top: 50%;
  transform: translateY(-50%);
  font-size: 88rpx; opacity: 0.75;
}
.cta-coach-content {
  position: absolute; left: 28rpx; top: 28rpx;
}
.cta-coach-title-row {
  display: flex; align-items: center; gap: 12rpx; margin-bottom: 14rpx;
}
.cta-coach-title {
  font-size: 36rpx; font-weight: 900; color: #FFFFFF; letter-spacing: -1rpx;
}
.cta-coach-beta {
  font-size: 18rpx; font-weight: 600; color: #8899EE;
  border: 1.5rpx solid rgba(136,153,238,0.55);
  border-radius: 100rpx; padding: 3rpx 14rpx;
  line-height: 1.6;
}
.cta-coach-sub {
  display: block;
  font-size: 22rpx; color: rgba(255,255,255,0.5); line-height: 1.8;
}
.cta-coach-arrow {
  position: absolute; right: 20rpx; bottom: 20rpx;
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: rgba(255,255,255,0.1);
  border: 1.5rpx solid rgba(255,255,255,0.18);
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: rgba(255,255,255,0.8);
}
.cta-pressed { opacity: 0.85; }

/* ── Today 模块 ───────────────────────────── */
.today-card {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #0D2015 0%, #162A1C 100%);
  border: 1rpx solid rgba(178,255,51,0.18);
  border-radius: 32rpx; padding: 32rpx;
  position: relative; overflow: hidden;
}
.today-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 24rpx;
}
.today-header-left { display: flex; align-items: baseline; gap: 8rpx; }
.today-label-txt {
  font-size: 22rpx; font-weight: 900; color: #B2FF33; letter-spacing: 2rpx;
}
.today-date-txt { font-size: 22rpx; color: rgba(255,255,255,0.35); }
.today-records-link { font-size: 24rpx; color: rgba(178,255,51,0.7); }
.today-plan-badge {
  font-size: 20rpx; font-weight: 700; color: #0A1C10;
  background: #B2FF33; border-radius: 100rpx; padding: 4rpx 18rpx;
}

/* 今天未打球 - 训练推荐 */
.today-plan-title {
  font-size: 44rpx; font-weight: 900; color: #FFFFFF; margin-bottom: 12rpx; line-height: 1.2;
}
.today-plan-sub { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 24rpx; }
.today-plan-meta-row { display: flex; align-items: center; gap: 10rpx; margin-bottom: 32rpx; }
.today-meta-item { font-size: 24rpx; color: rgba(255,255,255,0.55); }
.today-meta-sep { font-size: 24rpx; color: rgba(255,255,255,0.2); }

/* 今天已打球 */
.today-played-row { display: flex; align-items: flex-start; gap: 20rpx; margin-bottom: 28rpx; }
.today-check-circle {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: rgba(178,255,51,0.15); border: 2rpx solid #B2FF33;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: #B2FF33; font-weight: 900; flex-shrink: 0;
}
.today-played-info { display: flex; flex-direction: column; gap: 8rpx; flex: 1; }
.today-played-title { font-size: 34rpx; font-weight: 800; color: #FFFFFF; }
.today-played-meta { font-size: 24rpx; color: rgba(255,255,255,0.5); }
.today-streak-line { font-size: 24rpx; color: #B2FF33; }

/* 按钮组 */
.today-actions { display: flex; gap: 16rpx; }
.today-btn-primary {
  flex: 1; height: 84rpx; border-radius: 100rpx;
  background: #B2FF33; color: #0A1C10;
  font-size: 28rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
}
.today-btn-secondary {
  height: 84rpx; padding: 0 32rpx; border-radius: 100rpx;
  border: 1rpx solid rgba(255,255,255,0.18);
  color: rgba(255,255,255,0.65);
  font-size: 28rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
}
.today-btn-pressed { opacity: 0.8; }

/* 邀请 Banner 间距 */
.home-section-pad { padding: 0 24rpx 20rpx; }

/* 挥拍摘要 */
.swing-summary-row {
  display: flex; align-items: flex-start; gap: 24rpx;
}
.swing-summary-item { display: flex; flex-direction: column; gap: 6rpx; align-items: center; min-width: 120rpx; }
.swing-summary-val { font-size: 44rpx; font-weight: 900; color: #FFFFFF; line-height: 1; }
.swing-summary-lbl { font-size: 22rpx; color: rgba(255,255,255,0.4); }
.swing-last-block {
  flex: 1; display: flex; flex-direction: column; gap: 8rpx;
  padding-left: 24rpx; border-left: 1rpx solid rgba(255,255,255,0.1);
}
.swing-last-date { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.swing-last-detail { font-size: 22rpx; color: rgba(255,255,255,0.35); line-height: 1.5; }

/* 球搭子横向滚动 */
.partners-hscroll { display: flex; white-space: nowrap; }
.partner-chip {
  display: inline-flex; flex-direction: column; align-items: center; gap: 10rpx;
  width: 130rpx; flex-shrink: 0; margin-right: 24rpx;
}
.partner-chip-av-wrap { position: relative; }
.partner-chip-av-img {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  border: 2rpx solid rgba(43,182,115,0.4);
}
.partner-chip-av-letter {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; font-weight: 900; color: #FFFFFF;
}
.partner-chip-name {
  font-size: 24rpx; font-weight: 600; color: rgba(255,255,255,0.85);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  max-width: 120rpx; text-align: center; display: block;
}
.partner-chip-last { font-size: 20rpx; color: rgba(255,255,255,0.35); text-align: center; display: block; }
.partner-chip-add .partner-chip-add-circle {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  border: 2rpx dashed rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
}
.partner-add-plus { font-size: 44rpx; color: rgba(255,255,255,0.3); line-height: 1; }
