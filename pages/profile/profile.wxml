<scroll-view class="home-page" scroll-y>

  <!-- ── 主页面 ── -->
  <view>

    <!-- Hero Section -->
    <view class="hero-section" style="padding-top:{{statusBarHeight + 12}}px">

      <!-- Logo -->
      <view class="brand-logo">
        <text class="brand-tennis">Tennis</text><text class="brand-f">F</text>
      </view>

      <!-- 问候区 -->
      <view class="home-greeting-wrap">
        <view class="home-av-wrap" bindtap="goEdit">
          <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="home-av-img" mode="aspectFill" />
          <view wx:elif="{{hasProfile}}" class="home-av-letter" style="background:{{avatarColor}}">{{nickname.slice(-1)}}</view>
          <view wx:else class="home-av-letter home-av-guest">?</view>
          <view wx:if="{{isActiveToday}}" class="home-av-dot"></view>
        </view>
        <view class="home-greeting-text">
          <view wx:if="{{hasProfile}}" class="greeting-hi">Hi, {{nickname}}<view class="greeting-edit-icon" bindtap="goEdit">✎</view></view>
          <view wx:else class="greeting-hi greeting-guest">登录后记录你的成长</view>
        </view>
      </view>

      <!-- 运动轨迹（旋转容器，右上→左下） -->
      <view class="streak-bg">
        <view class="streak s1"></view>
        <view class="streak s2"></view>
        <view class="streak s3"></view>
      </view>

      <!-- 粒子（独立于旋转容器） -->
      <view class="p p1"></view>
      <view class="p p2"></view>
      <view class="p p3"></view>
      <view class="p p4"></view>
      <view class="p p5"></view>
      <view class="p p6"></view>

    </view>

    <!-- 数据统计行 -->
    <view class="home-stats-row">
      <view class="home-stat">
        <view class="home-stat-val">{{hasProfile ? (player.ntrpLevel || (levelInfo ? levelInfo.range : '--')) : '--'}}</view>
        <view class="home-stat-tags">
          <text class="stat-ntrp-tag">NTRP等级</text>
          <text class="stat-style-tag" wx:if="{{styleLabel}}">{{styleLabel}}</text>
        </view>
      </view>
      <view class="stat-sep"></view>
      <view class="home-stat">
        <view class="home-stat-val">{{hasProfile ? totalHoursNum : '--'}}<text wx:if="{{hasProfile}}" class="stat-unit">h</text></view>
        <view class="home-stat-lbl">累计训练</view>
      </view>
      <view class="stat-sep"></view>
      <view class="home-stat">
        <view class="home-stat-val">{{hasProfile ? streak : '--'}}<text wx:if="{{hasProfile}}" class="stat-unit">天</text></view>
        <view class="home-stat-lbl">连续打球</view>
      </view>
    </view>

    <!-- 未登录引导卡 -->
    <view wx:if="{{!hasProfile}}" class="home-card guest-card" bindtap="goLogin">
      <view class="guest-card-inner">
        <view class="guest-card-icon">🎾</view>
        <view class="guest-card-title">登录后解锁完整功能</view>
        <view class="guest-card-desc">记录球局 · 追踪成长 · 连接球友</view>
        <view class="guest-login-btn">立即登录 →</view>
      </view>
    </view>

    <!-- 球员档案卡 -->
    <view class="home-card" wx:if="{{techScores}}">
      <view class="home-card-hd">
        <view class="home-card-title-wrap">
          <text class="home-card-title">球员档案</text>
          <text class="home-card-info-icon">ⓘ</text>
        </view>
      </view>
      <view class="profile-card-body">
        <canvas id="radar" type="2d" class="home-radar-canvas {{radarImgSrc ? 'radar-offscreen' : ''}}"></canvas>
        <image wx:if="{{radarImgSrc}}" src="{{radarImgSrc}}" class="home-radar-canvas" mode="aspectFill" />
        <view class="profile-insight">
          <text class="insight-line">{{insightLine1}}</text>
          <text class="insight-line">{{insightLine2}}</text>
          <text class="insight-line insight-dim">让技术更全面</text>
          <view class="skill-report-btn" bindtap="goEdit">
            <text class="skill-report-icon">📋</text>
            <text class="skill-report-txt">技能分析报告</text>
          </view>
        </view>
      </view>
    </view>

    <!-- CTA 入口行（未登录） -->
    <view wx:if="{{!hasProfile}}" class="cta-row">
      <view class="cta-card-training" hover-class="cta-pressed" hover-stay-time="100" bindtap="goTraining">
        <image class="cta-train-player" src="/images/tennis-player.png" mode="aspectFit" />
        <view class="cta-train-glow"></view>
        <view class="cta-train-content">
          <view class="cta-train-title">开始训练</view>
          <text class="cta-train-sub">针对性训练计划</text>
          <text class="cta-train-sub">提升技术能力</text>
        </view>
        <view class="cta-train-arrow">→</view>
      </view>
      <view class="cta-card-coach" hover-class="cta-pressed" hover-stay-time="100" bindtap="openAICoach">
        <view class="cta-coach-glow"></view>
        <view class="cta-coach-brain">🧠</view>
        <view class="cta-coach-content">
          <view class="cta-coach-title-row">
            <text class="cta-coach-title">教练</text>
            <view class="cta-coach-beta">Beta</view>
          </view>
          <text class="cta-coach-sub">分析你的表现</text>
          <text class="cta-coach-sub">给出专业建议</text>
        </view>
        <view class="cta-coach-arrow">→</view>
      </view>
    </view>

    <!-- Today 模块（已登录） -->
    <view wx:if="{{hasProfile}}" class="today-card">

      <!-- 今天已打球 -->
      <view wx:if="{{isActiveToday}}" class="today-played-wrap">
        <view class="today-header">
          <view class="today-header-left">
            <text class="today-label-txt">今日</text>
            <text class="today-date-txt">· {{todayDateText}}</text>
          </view>
          <view class="today-records-link" bindtap="goTrainingRecords">查看记录 ›</view>
        </view>
        <view class="today-played-row">
          <view class="today-check-circle">✓</view>
          <view class="today-played-info">
            <view class="today-played-title">今天已打球 🎾</view>
            <text wx:if="{{todaySessionInfo}}" class="today-played-meta">{{todaySessionInfo.location}} · {{todaySessionInfo.durationText}} · {{todaySessionInfo.partners}}</text>
            <text wx:if="{{streak > 1}}" class="today-streak-line">已连续 {{streak}} 天坚持 💪</text>
          </view>
        </view>
        <view class="today-actions">
          <view class="today-btn-primary" hover-class="today-btn-pressed" bindtap="goTraining">再来一练</view>
          <view class="today-btn-secondary" hover-class="today-btn-pressed" bindtap="openAICoach">教练助手</view>
        </view>
      </view>

      <!-- 今天未打球 - 个性化推荐 -->
      <view wx:else class="today-plan-wrap">
        <view class="today-header">
          <view class="today-header-left">
            <text class="today-label-txt">今日</text>
            <text class="today-date-txt">· {{todayDateText}}</text>
          </view>
          <view class="today-plan-badge">{{todayPlan.badge}}</view>
        </view>
        <view class="today-plan-title">{{todayPlan.title}}</view>
        <view class="today-plan-sub">{{todayPlan.sub}}</view>
        <view class="today-plan-meta-row">
          <text class="today-meta-item">⏱ {{todayPlan.duration}}分钟</text>
          <text class="today-meta-sep">·</text>
          <text class="today-meta-item">{{todayPlan.difficulty}}</text>
          <text class="today-meta-sep">·</text>
          <text class="today-meta-item">🔥 {{todayPlan.calories}}千卡</text>
        </view>
        <view class="today-actions">
          <view class="today-btn-primary" hover-class="today-btn-pressed" bindtap="goTraining">▶ 开始训练</view>
          <view class="today-btn-secondary" hover-class="today-btn-pressed" bindtap="goSquare">约球组局</view>
        </view>
      </view>

    </view>

    <!-- 约球邀请 Banner -->
    <view class="home-section-pad" wx:if="{{inviteCount > 0}}">
      <view class="invite-banner" bindtap="openInviteSheet">
        <text class="invite-banner-txt">🎾 有 {{inviteCount}} 条约球邀请</text>
        <text class="invite-banner-arr">›</text>
      </view>
    </view>

    <!-- 训练日历 -->
    <view class="home-card">
      <view class="home-card-hd" bindtap="goTrainingRecords">
        <text class="home-card-title">训练日历</text>
        <text class="home-card-more">本周训练 {{weeklyCount}} 次 ›</text>
      </view>
      <view class="weekly-grid">
        <view wx:for="{{weeklyDays}}" wx:key="date" wx:for-item="day" class="wd-col">
          <text class="wd-name {{day.isToday ? 'wd-today' : ''}}">{{day.dayName}}</text>
          <view class="wd-circle {{day.hasGame ? 'wd-on' : 'wd-off'}}">
            <text wx:if="{{day.hasGame}}" class="wd-ball">🎾</text>
          </view>
          <text class="wd-dur {{day.hasGame ? 'wd-dur-on' : ''}}">{{day.durationText || '—'}}</text>
        </view>
      </view>
    </view>

    <!-- 挥拍记录 -->
    <view class="home-card">
      <view class="home-card-hd">
        <text class="home-card-title">挥拍记录</text>
        <text class="home-card-sub-info" wx:if="{{swingStats.sessions > 0}}">{{swingStats.sessions}} 次训练</text>
      </view>
      <view wx:if="{{swingStats.sessions > 0}}" class="swing-summary-row">
        <view class="swing-summary-item">
          <view class="swing-summary-val">{{swingTotal}}</view>
          <view class="swing-summary-lbl">累计挥拍</view>
        </view>
        <view class="swing-summary-item">
          <view class="swing-summary-val">{{swingStats.sessions}}</view>
          <view class="swing-summary-lbl">训练次数</view>
        </view>
        <view class="swing-last-block" wx:if="{{swingStats.lastSession}}">
          <view class="swing-last-date">最近 {{swingStats.lastSession.dateText}}</view>
          <view class="swing-last-detail">正手{{swingStats.lastSession.fh}} · 反手{{swingStats.lastSession.bh}} · 发球{{swingStats.lastSession.sv}}</view>
        </view>
      </view>
      <view wx:else class="swing-empty">
        <text class="swing-empty-icon">⌚</text>
        <text class="swing-empty-txt">完成训练后可上报手表挥拍数据</text>
      </view>
    </view>

    <!-- 球搭子 -->
    <view wx:if="{{!hasProfile}}" class="home-card">
      <view class="home-card-hd">
        <text class="home-card-title">球搭子</text>
      </view>
      <view class="partners-empty-guest">
        <text class="partners-empty-icon">👥</text>
        <text class="partners-empty-txt">登录后查看你的球搭子</text>
      </view>
    </view>
    <view class="home-card" wx:elif="{{partners.length > 0}}">
      <view class="home-card-hd">
        <text class="home-card-title">球搭子</text>
      </view>
      <scroll-view class="partners-hscroll" scroll-x enable-flex>
        <view wx:for="{{partners}}" wx:key="name" wx:for-item="p"
              class="partner-chip" bindtap="viewPartner" data-name="{{p.name}}">
          <view class="partner-chip-av-wrap">
            <image wx:if="{{p.avatarUrl}}" src="{{p.avatarUrl}}" class="partner-chip-av-img" mode="aspectFill" />
            <view wx:else class="partner-chip-av-letter" style="background:{{p.color}}">{{p.initial}}</view>
          </view>
          <text class="partner-chip-name">{{p.name}}</text>
          <text class="partner-chip-last">{{p.lastText ? p.lastText : p.count + '场'}}</text>
        </view>
      </scroll-view>
    </view>

    <view style="height:80rpx;"></view>
  </view>

</scroll-view>

<!-- ══ 约球邀请 Sheet ══ -->
<view class="sheet-overlay" wx:if="{{showInviteSheet}}" bindtap="closeInviteSheet">
  <view class="bottom-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-title">约球邀请</view>
    <view wx:for="{{invites}}" wx:key="_id" wx:for-item="inv" class="invite-item">
      <view class="invite-from-row">
        <text class="invite-from-name">{{inv.fromNickname}}</text>
        <text class="invite-from-label"> 想约你打球 🎾</text>
      </view>
      <view class="invite-actions">
        <view class="invite-ignore" catchtap="ignoreInvite" data-id="{{inv._id}}">先忽略</view>
        <view class="invite-accept" catchtap="acceptInvite" data-id="{{inv._id}}" data-from="{{inv.fromNickname}}">接受约球 →</view>
      </view>
    </view>
  </view>
</view>

<!-- ══ 日期 Day Sheet ══ -->
<view class="sheet-overlay" wx:if="{{showDaySheet}}" bindtap="closeDaySheet">
  <view class="bottom-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-title">{{daySheetDate}}</view>
    <view wx:if="{{daySheetGames.length === 0}}" class="sheet-empty">暂无球局记录</view>
    <view wx:for="{{daySheetGames}}" wx:key="_id" wx:for-item="g" class="sheet-game-item"
          bindtap="goDetailFromTimeline" data-id="{{g._id}}">
      <view class="sgi-left">
        <view class="sgi-dot" style="background:{{g.levelInfo ? g.levelInfo.color : '#2BB673'}}"></view>
      </view>
      <view class="sgi-content">
        <view class="sgi-location">{{g.location}}</view>
        <view class="sgi-meta">{{g.time}} · {{g.partners}}</view>
      </view>
      <view class="sgi-arrow">›</view>
    </view>
  </view>
</view>


<!-- ══ 留言 Sheet ══ -->
<view class="sheet-overlay" wx:if="{{noteSheetOpen}}" bindtap="closeNoteSheet">
  <view class="bottom-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-title">给 {{activeNotePartner}} 留言</view>
    <textarea class="note-textarea" placeholder="写下你们的专属备注..." value="{{noteInput}}"
              bindinput="onNoteInput" maxlength="50" focus="{{noteSheetOpen}}" />
    <text class="note-char-count">{{noteInput.length}}/50</text>
    <view class="note-actions">
      <view class="note-clear" bindtap="clearNote">清除</view>
      <view class="note-submit" bindtap="submitNote">保存</view>
    </view>
  </view>
</view>
