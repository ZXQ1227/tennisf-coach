<scroll-view class="page" scroll-y>

  <!-- ── 无档案引导 ── -->
  <view class="setup-prompt" wx:if="{{!hasProfile}}">
    <view class="setup-prompt-hero">
      <view class="hero-glow"></view>
      <view class="prompt-avatar">🎾</view>
      <view class="prompt-title">建立你的球员档案</view>
      <view class="prompt-sub">记录成长，认识球友，建立你在 TennisF 的运动身份</view>
    </view>
    <view class="prompt-body">
      <view class="prompt-features">
        <view class="prompt-feature">
          <text class="feature-icon">📊</text>
          <view class="feature-info">
            <text class="feature-name">成长数据</text>
            <text class="feature-desc">记录每一场球局</text>
          </view>
        </view>
        <view class="prompt-feature">
          <text class="feature-icon">🤝</text>
          <view class="feature-info">
            <text class="feature-name">球友关系</text>
            <text class="feature-desc">找到固定球搭子</text>
          </view>
        </view>
        <view class="prompt-feature">
          <text class="feature-icon">🏆</text>
          <view class="feature-info">
            <text class="feature-name">成就系统</text>
            <text class="feature-desc">解锁专属运动称号</text>
          </view>
        </view>
      </view>
      <button class="create-btn" bindtap="goSetup">创建球员档案 →</button>
    </view>
  </view>

  <!-- ── 有档案的完整页面 ── -->
  <view wx:else>

    <!-- Hero 球员卡 -->
    <view class="hero">
      <view class="hero-glow-tl"></view>
      <view class="hero-glow-br"></view>

      <view class="hero-content">

        <!-- 头像 + 名字 + 编辑 -->
        <view class="hero-top">
          <view class="hero-av-wrap">
            <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="hero-av-img" mode="aspectFill" />
            <view wx:else class="hero-av-letter" style="background:{{avatarColor}}">
              {{nickname ? nickname.slice(-1) : '?'}}
            </view>
            <view wx:if="{{isActiveToday}}" class="hero-av-dot"></view>
          </view>
          <view class="hero-id">
            <view class="hero-name">{{nickname}}</view>
            <view class="hero-tags-row">
              <view wx:if="{{levelInfo}}" class="hero-tag-lvl" style="color:{{levelInfo.color}}">{{levelInfo.label}} {{levelInfo.range}}</view>
              <view wx:if="{{styleLabel}}" class="hero-tag-sty">{{styleLabel}}</view>
            </view>
            <view class="hero-pinned" wx:if="{{pinnedAchievList.length > 0}}">
              <text wx:for="{{pinnedAchievList}}" wx:key="key" wx:for-item="a" class="hero-pinned-badge">{{a.icon}} {{a.name}}</text>
            </view>
          </view>
          <button class="edit-btn" bindtap="goEdit">编辑</button>
        </view>

        <!-- Bio 签名 -->
        <view class="hero-bio" wx:if="{{bio}}">" {{bio}} "</view>

        <!-- 实时状态 -->
        <view class="hero-status-row" wx:if="{{lastActiveLabel}}">
          <view class="status-dot {{isActiveToday ? 'status-on' : 'status-off'}}"></view>
          <text class="status-txt">{{lastActiveLabel}}</text>
          <text class="status-court" wx:if="{{homeCourt}}"> · 📍 {{homeCourt}}</text>
        </view>

        <!-- 数据行 -->
        <view class="hero-nums-row">
          <view class="hero-num-item">
            <view class="hero-num-main">
              <text class="hero-num-val">{{totalHoursNum}}</text>
              <text class="hero-num-unit">{{totalHoursUnit}}</text>
            </view>
            <text class="hero-num-lbl">打球时长</text>
          </view>
          <view class="hero-num-sep"></view>
          <view class="hero-num-item">
            <text class="hero-num-val">{{monthlyGames}}</text>
            <text class="hero-num-lbl">本月场次</text>
          </view>
          <view class="hero-num-sep"></view>
          <view class="hero-num-item">
            <text class="hero-num-val">{{streak}}</text>
            <text class="hero-num-lbl">连续天</text>
          </view>
        </view>

        <!-- CTA -->
        <view class="hero-cta" bindtap="goPostTab">约球 🎾</view>

      </view>
    </view>

    <view class="body">

      <!-- 最近动态 -->
      <view class="card" wx:if="{{feedItems.length > 0}}">
        <view class="card-title">最近动态</view>
        <view class="feed-list">
          <view wx:for="{{feedItems}}" wx:key="index" wx:for-item="item"
                class="feed-item" bindtap="goFeedDetail" data-id="{{item.id}}">
            <view class="feed-icon-wrap">{{item.icon}}</view>
            <view class="feed-body">
              <text class="feed-text">{{item.text}}</text>
              <text class="feed-sub" wx:if="{{item.sub}}">{{item.sub}}</text>
            </view>
            <view class="feed-chevron" wx:if="{{item.type === 'game'}}">›</view>
          </view>
        </view>
      </view>

      <!-- 本周节奏 -->
      <view class="card weekly-card">
        <view class="weekly-hd">
          <text class="card-title" style="margin-bottom:0">本周节奏</text>
          <view class="weekly-streak-badge" wx:if="{{streak > 1}}">🔥 {{streak}} 天</view>
        </view>
        <view class="weekly-grid">
          <view wx:for="{{weeklyDays}}" wx:key="date" wx:for-item="day" class="weekly-day">
            <text class="weekly-day-name {{day.isToday ? 'weekly-day-today' : ''}}">{{day.dayName}}</text>
            <view class="weekly-ball-wrap">
              <view class="weekly-ball {{day.hasGame ? 'weekly-ball-on' : 'weekly-ball-off'}}">
                <text wx:if="{{day.hasGame}}" class="weekly-ball-txt">🎾</text>
              </view>
            </view>
            <text class="weekly-dur {{day.hasGame ? 'weekly-dur-on' : ''}}">{{day.durationText || '—'}}</text>
          </view>
        </view>
      </view>

      <!-- 球搭子 -->
      <view class="card" wx:if="{{partners.length > 0}}">
        <view class="card-title">球搭子</view>
        <view class="pl-list">
          <view wx:for="{{partners}}" wx:key="name" wx:for-item="p" class="pl-row"
                bindtap="viewPartner" data-name="{{p.name}}">
            <!-- 头像 -->
            <image wx:if="{{p.avatarUrl}}" src="{{p.avatarUrl}}" class="pl-av-img" mode="aspectFill" />
            <view wx:else class="pl-av" style="background:{{p.color}}">{{p.initial}}</view>
            <!-- 名字 + 称号 + 上次时间 -->
            <view class="pl-info">
              <view class="pl-name-row">
                <text class="pl-name">{{p.name}}</text>
                <view class="pl-chip {{p.isStrong ? 'pl-chip-strong' : ''}}">{{p.titleIcon}} {{p.title}}</view>
              </view>
              <text class="pl-meta">{{p.count}}场 · {{p.lastText || ''}}</text>
            </view>
            <!-- 再约一次 -->
            <view class="pl-invite" catchtap="invitePartner" data-name="{{p.name}}">再约</view>
          </view>
        </view>
      </view>

      <!-- 成就 -->
      <view class="card">
        <view class="card-title-row">
          <text class="card-title">成就</text>
          <text class="card-title-sub">{{earnedCount}}/{{achievements.length}} 已解锁</text>
        </view>
        <view class="achievements-grid">
          <view wx:for="{{achievements}}" wx:key="name" wx:for-item="a"
            class="achievement-item {{a.earned ? (a.pinned ? 'achievement-pinned' : '') : 'achievement-locked'}}"
            bindtap="onAchievTap" data-index="{{index}}">
            <text class="achievement-icon">{{a.icon}}</text>
            <text class="achievement-name">{{a.name}}</text>
            <text class="achievement-desc">{{a.desc}}</text>
            <view wx:if="{{a.pinned && a.earned}}" class="achievement-pin-badge">置顶</view>
          </view>
        </view>
      </view>

      <!-- 比赛回忆 -->
      <view wx:if="{{recentGames.length > 0}}">
        <view class="card-title" style="padding:0 32rpx 12rpx">比赛回忆</view>
        <view class="rm-list">
          <view wx:for="{{recentGames}}" wx:key="_id" wx:for-item="g"
                class="rm-card {{g.cancelled ? 'rm-card-dim' : ''}}"
                bindtap="goDetailFromTimeline" data-id="{{g._id}}">

            <!-- 媒体条 -->
            <view class="rm-media-strip" wx:if="{{g.hasMedia}}">
              <image wx:for="{{g.mediaUrls}}" wx:key="*this" wx:for-item="url"
                     src="{{url}}" class="rm-media-thumb" mode="aspectFill" />
            </view>

            <!-- 卡片主体 -->
            <view class="rm-body">

              <!-- 球场 + 时间 -->
              <view class="rm-hd">
                <text class="rm-location">{{g.location || '未知球场'}}</text>
                <text class="rm-date">{{g.dayAgoText}} {{g.time}}</text>
              </view>

              <!-- 对阵行（有对手） -->
              <view class="rm-vs-wrap" wx:if="{{g.hasOpponent}}">
                <view class="rm-side">
                  <view class="rm-av rm-av-me" style="background:{{avatarColor}}">我</view>
                  <text class="rm-av-name">我</text>
                </view>
                <view class="rm-vs-mid">
                  <text wx:if="{{g.scoreText}}" class="rm-score">{{g.scoreText}}</text>
                  <text wx:else class="rm-vs-dash">VS</text>
                </view>
                <view class="rm-side">
                  <view class="rm-av-group">
                    <view wx:for="{{g.opponentAvatars}}" wx:key="name" wx:for-item="av"
                          class="rm-av rm-av-opp"
                          style="background:{{av.color}};margin-left:{{index > 0 ? '-16rpx' : '0'}}">{{av.initial}}</view>
                  </view>
                  <text class="rm-av-name">{{g.opponentText}}</text>
                </view>
              </view>

              <!-- 独自练球 -->
              <view class="rm-solo-wrap" wx:else>
                <view class="rm-av rm-av-me" style="background:{{avatarColor}}">我</view>
                <text class="rm-solo-vibe">{{g.vibeText}}</text>
              </view>

              <!-- 底部标签行 -->
              <view class="rm-ft">
                <view class="rm-tags">
                  <view wx:if="{{g.levelInfo}}" class="rm-tag-lv"
                        style="color:{{g.levelInfo.color}};border-color:{{g.levelInfo.color}}">{{g.levelInfo.label}}</view>
                  <view wx:if="{{g.matchLabel}}" class="rm-tag">{{g.matchLabel}}</view>
                  <view wx:if="{{g.cancelled}}" class="rm-tag rm-tag-cancel">已取消</view>
                </view>
                <view class="rm-ft-right">
                  <text class="rm-dur">{{g.durationText}}</text>
                  <view wx:if="{{g.hasMedia}}" class="rm-media-pill">📷 {{g.mediaCount}}</view>
                  <text class="rm-arrow">›</text>
                </view>
              </view>

            </view>
          </view>
        </view>
      </view>

      <view class="empty-wrap" wx:if="{{!loading && totalGames === 0 && hasProfile}}">
        <text class="empty-emoji">🎾</text>
        <text class="empty-text">去约球广场找第一场球局吧</text>
      </view>

    </view>
  </view>

</scroll-view>

<!-- ── 日期 Day Sheet ── -->
<view class="sheet-overlay" wx:if="{{showDaySheet}}" bindtap="closeDaySheet">
  <view class="bottom-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-title">{{daySheetDate}}</view>
    <view wx:if="{{daySheetGames.length === 0}}" class="sheet-empty">暂无球局记录</view>
    <view wx:for="{{daySheetGames}}" wx:key="_id" wx:for-item="g" class="sheet-game-item"
          bindtap="goDetailFromTimeline" data-id="{{g._id}}">
      <view class="sgi-left">
        <view class="sgi-dot" style="background:{{g.levelInfo ? g.levelInfo.color : '#2BB673'}}"></view>
      </view>
      <view class="sgi-content">
        <view class="sgi-location">{{g.location}}</view>
        <view class="sgi-meta">{{g.time}} · {{g.partners}}</view>
      </view>
      <view class="sgi-arrow">›</view>
    </view>
  </view>
</view>

<!-- ── 留言 Sheet ── -->
<view class="sheet-overlay" wx:if="{{noteSheetOpen}}" bindtap="closeNoteSheet">
  <view class="bottom-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-title">给 {{activeNotePartner}} 留言</view>
    <textarea class="note-textarea" placeholder="写下你们的专属备注..." value="{{noteInput}}"
              bindinput="onNoteInput" maxlength="50" focus="{{noteSheetOpen}}" />
    <text class="note-char-count">{{noteInput.length}}/50</text>
    <view class="note-actions">
      <view class="note-clear" bindtap="clearNote">清除</view>
      <view class="note-submit" bindtap="submitNote">保存</view>
    </view>
  </view>
</view>

<!-- ── 成就详情 Sheet ── -->
<view class="sheet-overlay" wx:if="{{showAchievSheet}}" bindtap="closeAchievSheet">
  <view class="bottom-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view wx:if="{{activeAchiev}}" class="achiev-detail">
      <text class="achiev-big-icon">{{activeAchiev.icon}}</text>
      <view class="achiev-detail-name">{{activeAchiev.name}}</view>
      <view class="achiev-detail-desc">{{activeAchiev.desc}}</view>
      <view wx:if="{{activeAchiev.earned}}" class="achiev-actions">
        <view class="achiev-pin-btn {{activeAchiev.pinned ? 'achiev-pin-active' : ''}}" bindtap="togglePin">
          {{activeAchiev.pinned ? '✓ 已置顶展示' : '置顶展示（最多3个）'}}
        </view>
      </view>
      <view wx:else class="achiev-locked-hint">继续努力，解锁这个成就 💪</view>
    </view>
  </view>
</view>
