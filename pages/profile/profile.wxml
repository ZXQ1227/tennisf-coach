<scroll-view class="page-dark" scroll-y>

  <!-- ── 无档案引导 ── -->
  <view class="setup-prompt" wx:if="{{!hasProfile}}">
    <view class="setup-prompt-hero">
      <view class="hero-glow-tl"></view>
      <text class="prompt-avatar">🎾</text>
      <view class="prompt-title">建立你的球员档案</view>
      <view class="prompt-sub">记录成长，认识球友，建立你在 TennisF 的运动身份</view>
    </view>
    <view class="prompt-body">
      <view class="prompt-features">
        <view class="prompt-feature">
          <text class="feature-icon">📊</text>
          <view class="feature-info">
            <text class="feature-name">成长数据</text>
            <text class="feature-desc">记录每一场球局</text>
          </view>
        </view>
        <view class="prompt-feature">
          <text class="feature-icon">🤝</text>
          <view class="feature-info">
            <text class="feature-name">球友关系</text>
            <text class="feature-desc">找到固定球搭子</text>
          </view>
        </view>
        <view class="prompt-feature">
          <text class="feature-icon">🏆</text>
          <view class="feature-info">
            <text class="feature-name">成就系统</text>
            <text class="feature-desc">解锁专属运动称号</text>
          </view>
        </view>
      </view>
      <button class="create-btn" bindtap="goSetup">创建球员档案 →</button>
    </view>
  </view>

  <!-- ── 有档案的完整页面 ── -->
  <view wx:else>

    <!-- ══ HERO 球员卡 ══ -->
    <view class="hero-dark">
      <view class="hero-glow-tl"></view>
      <view class="hero-glow-br"></view>
      <view class="hero-content">

        <!-- 头像 + 昵称 + 编辑 -->
        <view class="hero-top">
          <view class="hero-av-wrap">
            <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="hero-av-img" mode="aspectFill" />
            <view wx:else class="hero-av-letter" style="background:{{avatarColor}}">
              {{nickname ? nickname.slice(-1) : '?'}}
            </view>
            <view wx:if="{{isActiveToday}}" class="hero-av-dot"></view>
          </view>

          <view class="hero-id">
            <view class="hero-name">{{nickname}}</view>
            <view class="hero-tags-row">
              <view wx:if="{{player.ntrpLevel || levelInfo}}" class="hero-tag-lvl" style="color:{{levelInfo ? levelInfo.color : '#2BB673'}}">
                {{player.ntrpLevel ? 'NTRP ' + player.ntrpLevel : levelInfo.label + ' ' + levelInfo.range}}
              </view>
              <view wx:if="{{styleLabel}}" class="hero-tag-sty">{{styleLabel}}</view>
            </view>
          </view>

          <button class="edit-btn-glass" bindtap="goEdit">编辑</button>
        </view>

        <!-- Bio / 格言 -->
        <view class="hero-bio-wrap" wx:if="{{bio}}">
          <text class="bio-quote-mark">"</text>
          <text class="bio-text">{{bio}}</text>
          <text class="bio-quote-mark">"</text>
        </view>

        <!-- ── 技能掌握度模块 ── -->
        <view class="skill-module">
          <view class="hero-data-row">
            <view class="hero-stats-col">
              <text class="dark-card-title">技能掌握度</text>
              <view class="hours-spacer"></view>
              <text class="hours-lbl">累积练习时长 </text><text class="hours-val">{{totalHoursDisplay}}</text>
              <view class="hours-change-row" wx:if="{{hoursChangeStr}}">
                <text class="hours-change" style="color:{{hoursChangeColor}}">较上月 {{hoursChangeStr}}</text>
              </view>
              <view class="hero-status-row" wx:if="{{lastActiveLabel}}" style="margin-top:16rpx">
                <view class="status-dot {{isActiveToday ? 'status-on' : 'status-off'}}"></view>
                <text class="status-txt">{{lastActiveLabel}}</text>
              </view>
            </view>
            <view class="skill-divider"></view>
            <view class="hero-radar-wrap" wx:if="{{techScores}}">
              <canvas id="radar" type="2d" class="hero-radar-canvas"></canvas>
            </view>
          </view>
        </view>

        <!-- ── CTA 区 ── -->
        <view class="cta-row">
          <view class="cta-glow-btn cta-half" hover-class="cta-pressed" hover-stay-time="100" bindtap="goPostTab">
            约球 🎾
          </view>
          <view class="cta-ai-btn cta-ai-half" hover-class="cta-pressed" hover-stay-time="100" bindtap="openAICoach">
            AI 教练 ✨
          </view>
        </view>

      </view>
    </view>

    <!-- 约球邀请 Banner -->
    <view class="section-gap" wx:if="{{inviteCount > 0}}">
      <view class="invite-banner" bindtap="openInviteSheet">
        <text class="invite-banner-txt">🎾 有 {{inviteCount}} 条约球邀请</text>
        <text class="invite-banner-arr">›</text>
      </view>
    </view>

    <!-- ══ Body 区域 ══ -->
    <view class="body-dark">

      <!-- ── 本周节奏 ── -->
      <view class="dark-card">
        <view class="section-hd">
          <text class="dark-card-title" style="margin-bottom:0">本周节奏</text>
          <view class="streak-tag" wx:if="{{streak > 1}}">🔥 {{streak}} 天</view>
        </view>
        <view class="weekly-grid">
          <view wx:for="{{weeklyDays}}" wx:key="date" wx:for-item="day" class="wd-col">
            <text class="wd-name {{day.isToday ? 'wd-today' : ''}}">{{day.dayName}}</text>
            <view class="wd-circle {{day.hasGame ? 'wd-on' : 'wd-off'}}">
              <text wx:if="{{day.hasGame}}" class="wd-ball">🎾</text>
            </view>
            <text class="wd-dur {{day.hasGame ? 'wd-dur-on' : ''}}">{{day.durationText || '—'}}</text>
          </view>
        </view>
      </view>

      <!-- ── 球搭子 ── -->
      <view class="dark-card" wx:if="{{partners.length > 0}}">
        <view class="dark-card-title">球搭子</view>
        <view class="pl-list">
          <view wx:for="{{partners}}" wx:key="name" wx:for-item="p"
                class="pl-row" bindtap="viewPartner" data-name="{{p.name}}">
            <image wx:if="{{p.avatarUrl}}" src="{{p.avatarUrl}}" class="pl-av-img" mode="aspectFill" />
            <view wx:else class="pl-av" style="background:{{p.color}}">{{p.initial}}</view>
            <view class="pl-info">
              <view class="pl-name-row">
                <text class="pl-name">{{p.name}}</text>
                <view class="pl-chip {{p.isStrong ? 'pl-chip-strong' : ''}}">{{p.titleIcon}} {{p.title}}</view>
              </view>
              <text class="pl-meta">{{p.count}}场 · {{p.lastText || ''}}</text>
            </view>
            <view class="pl-invite" catchtap="invitePartner" data-name="{{p.name}}">再约</view>
          </view>
        </view>
      </view>

<!-- ── 比赛回忆 ── -->
      <view class="dark-card" wx:if="{{recentGames.length > 0}}">
        <view class="dark-card-title">训练记录</view>
        <view class="rl-list">
          <view wx:for="{{recentGames}}" wx:key="_id" wx:for-item="g"
                class="rl-row {{g.cancelled ? 'rl-dim' : ''}}"
                bindtap="goDetailFromTimeline" data-id="{{g._id}}">
            <text class="rl-meta">{{g.dayAgoText}} · {{g.location || '未知球场'}}</text>
            <text class="rl-main">{{g.rmDesc}}</text>
            <text class="rl-photo" wx:if="{{g.hasMedia}}">📸 {{g.mediaCount}} 张</text>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-wrap" wx:if="{{!loading && totalGames === 0 && hasProfile}}">
        <text class="empty-emoji">🎾</text>
        <text class="empty-text">去约球广场找第一场球局吧</text>
      </view>

      <view style="height:60rpx;"></view>
    </view>

  </view>
</scroll-view>

<!-- ══ 约球邀请 Sheet ══ -->
<view class="sheet-overlay" wx:if="{{showInviteSheet}}" bindtap="closeInviteSheet">
  <view class="bottom-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-title">约球邀请</view>
    <view wx:for="{{invites}}" wx:key="_id" wx:for-item="inv" class="invite-item">
      <view class="invite-from-row">
        <text class="invite-from-name">{{inv.fromNickname}}</text>
        <text class="invite-from-label"> 想约你打球 🎾</text>
      </view>
      <view class="invite-actions">
        <view class="invite-ignore" catchtap="ignoreInvite" data-id="{{inv._id}}">先忽略</view>
        <view class="invite-accept" catchtap="acceptInvite" data-id="{{inv._id}}" data-from="{{inv.fromNickname}}">接受约球 →</view>
      </view>
    </view>
  </view>
</view>

<!-- ══ 日期 Day Sheet ══ -->
<view class="sheet-overlay" wx:if="{{showDaySheet}}" bindtap="closeDaySheet">
  <view class="bottom-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-title">{{daySheetDate}}</view>
    <view wx:if="{{daySheetGames.length === 0}}" class="sheet-empty">暂无球局记录</view>
    <view wx:for="{{daySheetGames}}" wx:key="_id" wx:for-item="g" class="sheet-game-item"
          bindtap="goDetailFromTimeline" data-id="{{g._id}}">
      <view class="sgi-left">
        <view class="sgi-dot" style="background:{{g.levelInfo ? g.levelInfo.color : '#2BB673'}}"></view>
      </view>
      <view class="sgi-content">
        <view class="sgi-location">{{g.location}}</view>
        <view class="sgi-meta">{{g.time}} · {{g.partners}}</view>
      </view>
      <view class="sgi-arrow">›</view>
    </view>
  </view>
</view>

<!-- ══ 留言 Sheet ══ -->
<view class="sheet-overlay" wx:if="{{noteSheetOpen}}" bindtap="closeNoteSheet">
  <view class="bottom-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-title">给 {{activeNotePartner}} 留言</view>
    <textarea class="note-textarea" placeholder="写下你们的专属备注..." value="{{noteInput}}"
              bindinput="onNoteInput" maxlength="50" focus="{{noteSheetOpen}}" />
    <text class="note-char-count">{{noteInput.length}}/50</text>
    <view class="note-actions">
      <view class="note-clear" bindtap="clearNote">清除</view>
      <view class="note-submit" bindtap="submitNote">保存</view>
    </view>
  </view>
</view>

