@keyframes dot-live-anim {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.3; transform: scale(0.7); }
}

@keyframes dot-pulse-anim {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.page {
  padding: 0 0 220rpx;
  min-height: 100vh;
}

/* ── Hero ── */
.hero {
  background: linear-gradient(145deg, #1A9459 0%, #2BB673 100%);
  padding: 56rpx 40rpx 48rpx;
  margin-bottom: 32rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.hero-status-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(255,255,255,0.2);
  color: #FFFFFF;
  border-radius: 100rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.hero-status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFFFFF;
  flex-shrink: 0;
}

.dot-live-white { animation: dot-live-anim 1.5s ease-in-out infinite; }
.dot-pulse-white { animation: dot-pulse-anim 1s ease-in-out infinite; }

.share-btn {
  background: rgba(255,255,255,0.2);
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 24rpx;
  border: none;
}

.hero-location {
  font-size: 64rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1.2;
  margin-bottom: 16rpx;
  letter-spacing: -2rpx;
}

.hero-nav-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 100rpx;
  padding: 10rpx 24rpx 10rpx 16rpx;
  margin-bottom: 20rpx;
}
.hero-nav-icon { font-size: 26rpx; }
.hero-nav-txt { font-size: 24rpx; color: #FFFFFF; font-weight: 500; }
.hero-nav-arr { font-size: 30rpx; color: rgba(255,255,255,0.6); }

.hero-time-row {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 24rpx;
}

.hero-time-main {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: -0.5rpx;
}

.hero-time-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 36rpx;
}

.hero-tag {
  background: rgba(255,255,255,0.2);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.hero-tag-fee { background: rgba(215,255,63,0.25); color: #D7FF3F; }

.hero-footer {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hero-progress-bar {
  flex: 1;
  height: 6rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 100rpx;
  overflow: hidden;
}

.hero-progress-fill {
  height: 100%;
  background: #FFFFFF;
  border-radius: 100rpx;
}

.hero-progress-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  white-space: nowrap;
}

.hero-organizer {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
}

/* ── 内容区 ── */
.section { margin: 0 32rpx 28rpx; }

.section-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #BBBBBB;
  letter-spacing: 1rpx;
  margin-bottom: 14rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 20rpx rgba(0,0,0,0.05);
  border: 1rpx solid #F0F0F0;
}

.avatars-big { display: flex; flex-wrap: wrap; gap: 28rpx; }

.av-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.av-item:active { opacity: 0.7; }

.av-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.av-name {
  font-size: 20rpx;
  color: #999;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.contact-card { display: flex; align-items: center; gap: 16rpx; }
.contact-icon { font-size: 36rpx; }
.contact-text { font-size: 30rpx; color: #1A1A1A; font-weight: 500; }
.note-text { font-size: 28rpx; color: #555; line-height: 1.7; }

/* ── 底部栏 ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 24rpx rgba(0,0,0,0.08);
}

.bottom-tip {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 16rpx 0;
}

.bottom-row { display: flex; gap: 16rpx; align-items: center; }

.bottom-input {
  flex: 1;
  background: #F7F8FA;
  border-radius: 100rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  height: 88rpx;
}

.bottom-btn {
  background: #2BB673;
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 700;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 36rpx;
  white-space: nowrap;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(43,182,115,0.4);
}

.bottom-btn-soon {
  background: #FF6B2B;
  box-shadow: 0 6rpx 20rpx rgba(255,107,43,0.4);
}

.bottom-btn[disabled] { background: #CCC; box-shadow: none; }

.bottom-joined {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.joined-label { font-size: 30rpx; color: #2BB673; font-weight: 600; }

.cancel-btn {
  background: #FFF0F0;
  color: #FF6B6B;
  border-radius: 100rpx;
  font-size: 26rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  border: none;
}

.bottom-creator-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.creator-label { font-size: 28rpx; color: #1A1A1A; font-weight: 600; }

.cancel-game-btn {
  background: #FFF0F0;
  color: #FF6B6B;
  border-radius: 100rpx;
  font-size: 26rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  border: none;
}

.bottom-live {
  padding: 4rpx 0;
  width: 100%;
}

.live-info-col {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.tm-enter-btn {
  background: #A6FF33;
  border-radius: 100rpx;
  padding: 18rpx 24rpx;
  flex-shrink: 0;
}

.tm-enter-txt {
  font-size: 24rpx;
  font-weight: 800;
  color: #0B1A10;
  white-space: nowrap;
}

.live-indicator {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.live-dot-big {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-live-green {
  background: #2BB673;
  animation: dot-live-anim 1.5s ease-in-out infinite;
}

.live-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #2BB673;
}

.live-sub {
  font-size: 24rpx;
  color: #AAAAAA;
  padding-left: 30rpx;
}

.bottom-finished {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 4rpx 0;
}

.finished-main {
  font-size: 28rpx;
  color: #888;
  text-align: center;
  margin-bottom: 16rpx;
}

.finished-actions {
  display: flex;
  gap: 16rpx;
}

.poster-btn {
  flex: 1;
  background: #2BB673;
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 600;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(43,182,115,0.4);
}

.finished-btn {
  flex: 1;
  background: #F4F4F4;
  color: #555;
  border-radius: 100rpx;
  font-size: 26rpx;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
}

/* ── 参与者操作行 ── */
.live-participant-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.live-act-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 0;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.live-act-icon { font-size: 28rpx; }
.live-act-txt { font-size: 24rpx; font-weight: 700; }

.live-act-photo {
  background: rgba(43,182,115,0.10);
  border: 1.5rpx solid rgba(43,182,115,0.30);
  color: #2BB673;
}

.live-act-score {
  background: #F4F4F4;
  border: 1.5rpx solid #E8E8E8;
  color: #555;
}

/* ── 局分 Sheet ── */
.score-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  display: flex;
  align-items: flex-end;
  z-index: 500;
}

.score-sheet {
  width: 100%;
  background: #142B1C;
  border-radius: 40rpx 40rpx 0 0;
  padding: 20rpx 40rpx 60rpx;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

.ss-handle {
  width: 80rpx; height: 6rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 100rpx;
  margin: 0 auto 32rpx;
}

.ss-title { font-size: 32rpx; font-weight: 800; color: #FFFFFF; text-align: center; margin-bottom: 40rpx; }

.ss-score-row { display: flex; align-items: center; justify-content: center; margin-bottom: 32rpx; }

.ss-side { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.ss-side-label { font-size: 20rpx; color: rgba(255,255,255,0.38); font-weight: 600; letter-spacing: 2rpx; }

.ss-ctrl { display: flex; align-items: center; gap: 24rpx; }

.ss-sub, .ss-add {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; font-weight: 700;
}

.ss-sub { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.55); }
.ss-add { background: rgba(166,255,51,0.15); color: #A6FF33; border: 1rpx solid rgba(166,255,51,0.35); }

.ss-num { font-size: 80rpx; font-weight: 900; color: #FFFFFF; line-height: 1; min-width: 60rpx; text-align: center; }
.ss-colon { font-size: 64rpx; font-weight: 900; color: rgba(166,255,51,0.5); padding: 0 8rpx; padding-bottom: 16rpx; }

.ss-set-row { display: flex; align-items: center; justify-content: center; gap: 24rpx; margin-bottom: 36rpx; padding-top: 24rpx; border-top: 1rpx solid rgba(255,255,255,0.07); }
.ss-set-txt { font-size: 24rpx; color: rgba(255,255,255,0.45); }
.ss-set-next { font-size: 22rpx; color: rgba(166,255,51,0.75); border: 1rpx solid rgba(166,255,51,0.3); border-radius: 100rpx; padding: 10rpx 22rpx; }

.ss-confirm { background: #A6FF33; color: #0B1A10; font-size: 30rpx; font-weight: 800; text-align: center; padding: 30rpx 0; border-radius: 24rpx; }

/* ── 激战中底部栏 ── */
.live-creator-row, .live-joiner-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
}

/* 创建者：开关 */
.live-recruit-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}
.live-recruit-texts { display: flex; flex-direction: column; gap: 2rpx; }
.live-recruit-title { font-size: 26rpx; font-weight: 700; color: #1A1A1A; }
.live-recruit-sub { font-size: 20rpx; color: #2BB673; font-weight: 600; }

/* 非创建者：可加入 */
.live-already-row, .live-join-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  gap: 16rpx;
}
.live-already-txt { font-size: 26rpx; color: #2BB673; font-weight: 700; flex: 1; }

.live-join-info { flex: 1; }
.live-join-title { font-size: 26rpx; font-weight: 700; color: #1A1A1A; display: block; margin-bottom: 4rpx; }
.live-join-sub { font-size: 20rpx; color: #AAAAAA; display: block; }

.live-board-btn {
  background: #2BB673;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
  padding: 18rpx 28rpx;
  border-radius: 100rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(43,182,115,0.35);
}

/* 非创建者：已关闭/已满 */
.live-closed-row { width: 100%; }
.live-closed-txt { font-size: 24rpx; color: #AAAAAA; }

/* ── 球友头像图片 ── */
.av-circle-img { width: 96rpx; height: 96rpx; border-radius: 50%; border: 3rpx solid #FFFFFF; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12); }
.slot-av-img { width: 68rpx; height: 68rpx; border-radius: 50%; flex-shrink: 0; }
.slot-av-img-mine { box-shadow: 0 0 0 3rpx rgba(166,255,51,0.6); }
.slot-av-img-reserved { opacity: 0.55; }

/* ── 坑位展示 ── */
.invite-banner {
  display: flex; align-items: center; gap: 12rpx;
  background: linear-gradient(135deg, #E8F9F1, #D4F4E4);
  border: 1rpx solid rgba(43,182,115,0.35);
  border-radius: 20rpx; padding: 18rpx 24rpx; margin-bottom: 16rpx;
}
.invite-banner-icon { font-size: 32rpx; }
.invite-banner-txt { font-size: 26rpx; color: #1A8A50; font-weight: 600; flex: 1; line-height: 1.5; }

.slots-card { padding: 8rpx 0; }

.slot-row { padding: 16rpx 28rpx; border-bottom: 1rpx solid #F5F5F5; }
.slot-row:last-child { border-bottom: none; }
.slot-row-inner { display: flex; align-items: center; gap: 18rpx; }
.slot-row-inner:active { opacity: 0.7; }
.slot-row-mine { background: rgba(166,255,51,0.06); margin: 0 -28rpx; padding: 16rpx 28rpx; }
.slot-row-open { opacity: 0.6; }

.slot-av {
  width: 68rpx; height: 68rpx; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 700; color: #FFFFFF;
}
.slot-av-confirmed {}
.slot-av-mine { box-shadow: 0 0 0 3rpx rgba(166,255,51,0.6); }
.slot-av-reserved { opacity: 0.5; }
.slot-av-open { background: #EBEBEB; font-size: 34rpx; color: #AAAAAA; font-weight: 300; }

.slot-nick { flex: 1; font-size: 28rpx; font-weight: 600; color: #1A1A1A; }
.slot-nick-reserved { color: #999; }
.slot-nick-open { color: #BBBBBB; font-weight: 400; }

.slot-badge { font-size: 20rpx; font-weight: 700; padding: 6rpx 16rpx; border-radius: 100rpx; }
.slot-badge-confirmed { background: #E8F9F1; color: #2BB673; }
.slot-badge-mine { background: rgba(166,255,51,0.15); color: #5A8A00; }
.slot-badge-reserved { background: #FFF3E0; color: #D68910; }
.slot-badge-open { background: #F0F0F0; color: #999; }

/* ── 邀请响应底栏 ── */
.bottom-invite-row {
  display: flex; gap: 16rpx; padding: 12rpx 0;
}
.reject-btn {
  flex: 1; background: #F7F8FA; color: #888;
  border: 1rpx solid #E5E5E5; border-radius: 100rpx;
  font-size: 26rpx; font-weight: 600; height: 88rpx; line-height: 88rpx;
}
.accept-btn {
  flex: 2; background: #2BB673; color: #FFFFFF;
  border: none; border-radius: 100rpx;
  font-size: 28rpx; font-weight: 700; height: 88rpx; line-height: 88rpx;
  box-shadow: 0 8rpx 24rpx rgba(43,182,115,0.4);
}

/* ── 精彩瞬间 Gallery ── */
.gallery-wrap { margin: 0 -36rpx; }
.gallery-scroll { white-space: nowrap; }
.gallery-row { display: inline-flex; gap: 12rpx; padding: 4rpx 36rpx 8rpx; }
.gallery-thumb { width: 220rpx; height: 220rpx; border-radius: 20rpx; flex-shrink: 0; }

/* ── 昵称采集 Sheet ── */
.ns-sheet { padding-bottom: calc(32rpx + env(safe-area-inset-bottom)); }
.ns-title { font-size: 34rpx; font-weight: 700; color: #1A1A1A; text-align: center; margin-bottom: 40rpx; }
.ns-body { display: flex; align-items: center; gap: 24rpx; margin-bottom: 40rpx; padding: 0 8rpx; }
.ns-av-btn {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  padding: 0; margin: 0; background: #F0F0F0; border: none;
  flex-shrink: 0; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.ns-av-img { width: 100rpx; height: 100rpx; border-radius: 50%; display: block; }
.ns-av-ph {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: #E8F7EE;
  display: flex; align-items: center; justify-content: center;
}
.ns-av-initial { font-size: 38rpx; color: #2BB673; }
.ns-input {
  flex: 1; height: 88rpx;
  background: #F7F8FA; border-radius: 24rpx;
  padding: 0 28rpx; font-size: 32rpx; color: #1A1A1A;
  border: 1.5rpx solid #EBEBEB;
}
.ns-confirm {
  background: #2BB673; color: #FFFFFF;
  text-align: center; font-size: 32rpx; font-weight: 600;
  border-radius: 48rpx; padding: 28rpx 0;
}
