/* 设计 Token: 背景 #121C17 / 卡片 #1A2820 / 荧光绿 #B2FF33 */

.training-page { background: #121C17; min-height: 100vh; }

/* 顶部导航 */
.training-nav {
  display: flex; align-items: center; justify-content: space-between;
  padding-left: 20rpx; padding-right: 32rpx; padding-bottom: 16rpx;
}
.nav-back {
  width: 80rpx; height: 80rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #FFFFFF; font-weight: 300;
}
.nav-title { font-size: 36rpx; font-weight: 800; color: #FFFFFF; }
.nav-placeholder { width: 80rpx; }

/* 今日训练 Banner */
.today-plan-card {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #0A2818 0%, #132A1E 50%, #1A3525 100%);
  border: 1.5rpx solid rgba(178,255,51,0.25);
  border-radius: 32rpx; padding: 36rpx 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.5);
}
.plan-badge-row { margin-bottom: 16rpx; }
.plan-ai-badge {
  display: inline-block;
  font-size: 20rpx; font-weight: 700; color: #121C17;
  background: #B2FF33; border-radius: 100rpx;
  padding: 5rpx 18rpx; letter-spacing: 1rpx;
}
.plan-title { font-size: 44rpx; font-weight: 900; color: #FFFFFF; margin-bottom: 10rpx; }
.plan-sub { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 20rpx; }
.plan-meta-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 28rpx; }
.plan-meta-item { font-size: 24rpx; color: rgba(255,255,255,0.55); }
.plan-meta-sep { font-size: 24rpx; color: rgba(255,255,255,0.2); }
.plan-start-btn {
  display: flex; align-items: center; justify-content: center; gap: 14rpx;
  background: #B2FF33; border-radius: 100rpx;
  height: 88rpx; font-size: 30rpx; font-weight: 800;
  color: #0A1C10;
  box-shadow: 0 8rpx 24rpx rgba(178,255,51,0.4);
}
.plan-start-icon { font-size: 28rpx; }
.plan-start-txt { letter-spacing: 2rpx; }

/* Tabs */
.training-tabs {
  display: flex; gap: 0;
  padding: 0 24rpx 24rpx;
}
.training-tab {
  flex: 1; text-align: center;
  font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.4);
  padding: 18rpx 0;
  border-bottom: 3rpx solid rgba(255,255,255,0.1);
  transition: all 0.2s;
}
.tab-active {
  color: #B2FF33;
  border-bottom-color: #B2FF33;
}

/* 分区标题 */
.section-hd {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24rpx 20rpx;
}
.section-title { font-size: 28rpx; font-weight: 700; color: #FFFFFF; }
.section-more { font-size: 24rpx; color: rgba(255,255,255,0.4); }

/* 技术训练 2×3 网格 */
.skill-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 16rpx; padding: 0 24rpx 20rpx;
}
.skill-card {
  background: #1A2820;
  border: 1rpx solid rgba(255,255,255,0.07);
  border-radius: 24rpx; padding: 28rpx 24rpx;
  display: flex; flex-direction: column; gap: 10rpx;
  position: relative; overflow: hidden;
}
.skill-card-priority {
  border-color: rgba(178,255,51,0.35);
  background: linear-gradient(135deg, #1A2820 60%, rgba(178,255,51,0.06) 100%);
}
.skill-card-strength {
  border-color: rgba(43,182,115,0.25);
}
.skill-card-pressed { background: #1E3028; }
.skill-card-icon { font-size: 48rpx; }
.skill-card-name { font-size: 28rpx; font-weight: 700; color: rgba(255,255,255,0.9); }
.skill-card-count { font-size: 22rpx; color: rgba(255,255,255,0.35); }
.skill-priority-tag {
  position: absolute; top: 16rpx; right: 16rpx;
  font-size: 18rpx; font-weight: 700; color: #0A1C10;
  background: #B2FF33; border-radius: 100rpx;
  padding: 3rpx 14rpx;
}
.skill-strength-tag {
  position: absolute; top: 16rpx; right: 16rpx;
  font-size: 18rpx; font-weight: 700; color: #FFFFFF;
  background: rgba(43,182,115,0.5); border-radius: 100rpx;
  padding: 3rpx 14rpx;
}
.no-profile-tip {
  margin: 0 24rpx 24rpx;
  background: rgba(178,255,51,0.06);
  border: 1rpx solid rgba(178,255,51,0.2);
  border-radius: 20rpx; padding: 20rpx 28rpx;
}
.no-profile-txt {
  font-size: 24rpx; color: rgba(178,255,51,0.8);
}

/* 自定义训练行 */
.custom-train-row {
  display: flex; align-items: center; justify-content: space-between;
  margin: 4rpx 24rpx 0;
  background: #1A2820; border: 1rpx solid rgba(255,255,255,0.07);
  border-radius: 24rpx; padding: 28rpx;
}
.custom-train-left { display: flex; align-items: center; gap: 20rpx; }
.custom-train-icon { font-size: 44rpx; }
.custom-train-info { display: flex; flex-direction: column; gap: 6rpx; }
.custom-train-title { font-size: 28rpx; font-weight: 700; color: rgba(255,255,255,0.9); }
.custom-train-sub { font-size: 22rpx; color: rgba(255,255,255,0.35); }
.custom-train-arrow { font-size: 36rpx; color: rgba(255,255,255,0.25); }

/* 球局入口卡 */
.match-entry-card {
  display: flex; align-items: center; gap: 20rpx;
  margin: 0 24rpx 16rpx;
  background: #1A2820; border: 1rpx solid rgba(255,255,255,0.07);
  border-radius: 24rpx; padding: 28rpx;
}
.match-entry-icon-wrap {
  width: 80rpx; height: 80rpx; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.match-entry-icon { font-size: 40rpx; }
.match-entry-info { flex: 1; }
.match-entry-title { font-size: 28rpx; font-weight: 700; color: rgba(255,255,255,0.9); display: block; margin-bottom: 4rpx; }
.match-entry-sub { font-size: 22rpx; color: rgba(255,255,255,0.35); display: block; }
.match-entry-badge {
  font-size: 20rpx; font-weight: 600; color: #B2FF33;
  background: rgba(178,255,51,0.1); border: 1rpx solid rgba(178,255,51,0.25);
  border-radius: 100rpx; padding: 5rpx 16rpx; flex-shrink: 0;
}
.match-entry-arrow { font-size: 36rpx; color: rgba(255,255,255,0.2); flex-shrink: 0; }

/* 创建球局按钮 */
.create-match-btn {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  margin: 8rpx 24rpx 40rpx;
  background: rgba(178,255,51,0.08);
  border: 1.5rpx solid rgba(178,255,51,0.3);
  border-radius: 24rpx; height: 96rpx;
}
.create-match-plus { font-size: 36rpx; color: #B2FF33; }
.create-match-txt { font-size: 30rpx; font-weight: 700; color: #B2FF33; letter-spacing: 2rpx; }

/* 训练数据卡 */
.training-stats-card {
  margin: 0 24rpx 24rpx;
  background: #1A2820;
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 32rpx; padding: 32rpx;
}
.training-stats-hd {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx;
}
.training-stats-title { font-size: 28rpx; font-weight: 700; color: #FFFFFF; }
.training-stats-period { font-size: 24rpx; color: rgba(255,255,255,0.35); }
.training-stats-grid {
  display: flex; justify-content: space-around; margin-bottom: 28rpx;
}
.training-stat-box { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.training-stat-val { font-size: 44rpx; font-weight: 900; color: #FFFFFF; line-height: 1; }
.training-stat-unit { font-size: 22rpx; font-weight: 500; color: rgba(255,255,255,0.4); }
.training-stat-lbl { font-size: 22rpx; color: rgba(255,255,255,0.4); }

/* 周点阵 */
.training-week-dots { display: flex; justify-content: space-between; }
.week-dot-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.week-dot-name { font-size: 20rpx; color: rgba(255,255,255,0.3); }
.week-dot {
  width: 32rpx; height: 32rpx; border-radius: 50%;
}
.week-dot-on { background: #B2FF33; box-shadow: 0 0 10rpx rgba(178,255,51,0.5); }
.week-dot-off { background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.12); }

/* 组局比赛 Tab redirect */
.match-tab-redirect {
  display: flex; align-items: center; justify-content: center;
  padding: 60rpx 24rpx;
}
/* ── 组局比赛 Tab ── */
.match-tab-wrap { padding: 0 32rpx; }
.match-tab-topbar { display: flex; justify-content: flex-end; margin-bottom: 20rpx; }
.match-create-btn {
  display: flex; align-items: center; gap: 10rpx;
  background: #B2FF33; color: #0A1C10;
  font-size: 28rpx; font-weight: 800;
  padding: 18rpx 36rpx; border-radius: 999rpx;
}
.match-create-plus { font-size: 36rpx; font-weight: 300; line-height: 1; }
.match-create-txt { line-height: 1; }

.posts-loading { display: flex; justify-content: center; padding: 80rpx 0; }

/* Keyframes */
@keyframes dot-live {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.3; transform: scale(0.75); }
}
@keyframes dot-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
@keyframes spin-sm { to { transform: rotate(360deg) } }

/* Live Banner */
.live-banner {
  display: flex; align-items: center; gap: 12rpx;
  background: rgba(43,182,115,0.08);
  border: 1.5rpx solid rgba(43,182,115,0.28);
  border-radius: 20rpx; padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
}
.live-banner-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%;
  background: #2BB673; flex-shrink: 0;
  animation: dot-live 1.5s ease-in-out infinite;
}
.live-banner-text { font-size: 26rpx; font-weight: 600; color: #2BB673; flex: 1; }
.live-banner-arrow { font-size: 24rpx; color: rgba(43,182,115,0.65); }
.active-hint { font-size: 26rpx; color: #2BB673; font-weight: 600; margin-bottom: 16rpx; }

/* 空状态 */
.empty-wrap { display: flex; flex-direction: column; align-items: center; padding-top: 120rpx; }
.empty-emoji { font-size: 80rpx; margin-bottom: 28rpx; }
.empty-title { font-size: 34rpx; font-weight: 600; color: rgba(255,255,255,0.7); margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: rgba(255,255,255,0.3); margin-bottom: 48rpx; }
.empty-create-btn { background: #B2FF33; color: #0A1A0F; font-size: 28rpx; font-weight: 700; padding: 22rpx 64rpx; border-radius: 48rpx; }

/* 普通卡片 */
.card {
  background: #FFFFFF; border-radius: 40rpx;
  padding: 36rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(0,0,0,0.05);
  border: 2rpx solid #F0F0F0;
}
.card-starting-soon { border-color: #FF6B2B; background: #FFFAF7; }
.card-dim { opacity: 0.52; }
.card-status-row {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx;
}
.status-pill {
  display: flex; align-items: center; gap: 10rpx;
  padding: 10rpx 20rpx; border-radius: 100rpx;
  font-size: 22rpx; font-weight: 600;
}
.status-dot { width: 10rpx; height: 10rpx; border-radius: 50%; flex-shrink: 0; }
.dot-live { animation: dot-live 1.5s ease-in-out infinite; }
.dot-pulse { animation: dot-pulse 1s ease-in-out infinite; }
.time-label { font-size: 24rpx; color: #AAAAAA; font-weight: 500; }
.time-label-urgent { color: #FF6B2B; font-weight: 700; }
.time-label-live { color: #2BB673; font-weight: 600; }
.card-location {
  font-size: 46rpx; font-weight: 800; color: #1A1A1A;
  margin-bottom: 16rpx; line-height: 1.2; letter-spacing: -1rpx;
}
.card-distance { font-size: 28rpx; font-weight: 500; color: #2BB673; }
.card-tags { display: flex; gap: 10rpx; flex-wrap: wrap; margin-bottom: 28rpx; }
.tag {
  font-size: 22rpx; color: #888; background: #F4F4F4;
  padding: 6rpx 16rpx; border-radius: 14rpx; font-weight: 500;
}
.tag-level { font-weight: 700; }
.card-bottom {
  display: flex; justify-content: space-between; align-items: flex-end;
  padding-top: 24rpx; border-top: 1rpx solid #F5F5F5;
}
.spots-wrap { display: flex; flex-direction: column; gap: 6rpx; }
.spots-main { font-size: 34rpx; font-weight: 800; color: #1A1A1A; letter-spacing: -0.5rpx; }
.spots-dim { color: #AAAAAA; }
.spots-sub { font-size: 22rpx; color: #BBBBBB; }
.cta-btn { border-radius: 100rpx; font-size: 26rpx; font-weight: 700; padding: 18rpx 32rpx; }
.cta-joined { background: #E8F9F1; color: #2BB673; border: 1.5rpx solid rgba(43,182,115,0.3); }
.cta-recruiting { background: #2BB673; color: #FFFFFF; box-shadow: 0 4rpx 16rpx rgba(43,182,115,0.35); }
.cta-soon { background: #FF6B2B; color: #FFFFFF; }
.cta-full { background: #F4F4F4; color: #888; }
.cta-disabled { background: #F4F4F4; color: #BBBBBB; }

/* Live Card */
.live-card {
  background: #0E231A; border-radius: 40rpx; margin-bottom: 24rpx;
  overflow: hidden; border: 1.5rpx solid rgba(166,255,51,0.22);
  padding-bottom: 24rpx;
}
.lc-top {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 36rpx 0;
}
.lc-status-pill {
  display: flex; align-items: center; gap: 10rpx;
  background: rgba(166,255,51,0.12); border: 1rpx solid rgba(166,255,51,0.3);
  border-radius: 100rpx; padding: 10rpx 22rpx;
  font-size: 22rpx; font-weight: 700; color: #A6FF33;
}
.lc-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%;
  background: #A6FF33; animation: dot-live 1.5s ease-in-out infinite;
}
.lc-elapsed { font-size: 24rpx; color: rgba(255,255,255,0.45); font-weight: 500; }
.lc-sub-badge { font-size: 20rpx; font-weight: 600; }
.lc-venue {
  font-size: 52rpx; font-weight: 900; color: #FFFFFF;
  letter-spacing: -1rpx; line-height: 1.2; padding: 18rpx 36rpx 0;
}
.lc-distance { font-size: 36rpx; font-weight: 600; color: rgba(166,255,51,0.85); }
.lc-meta {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14rpx 36rpx 0;
}
.lc-tags { display: flex; gap: 10rpx; }
.lc-tag {
  font-size: 20rpx; color: rgba(255,255,255,0.45);
  background: rgba(255,255,255,0.07); border-radius: 12rpx; padding: 5rpx 14rpx;
}
.lc-players { font-size: 22rpx; color: rgba(255,255,255,0.35); }
.lc-score-row {
  display: flex; align-items: center; justify-content: center;
  padding: 28rpx 36rpx 0; gap: 0;
}
.lc-score-block { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.lc-score-num { font-size: 88rpx; font-weight: 900; line-height: 1; letter-spacing: -3rpx; }
.lc-score-a { color: #FFFFFF; }
.lc-score-b { color: rgba(255,255,255,0.45); }
.lc-score-name { font-size: 20rpx; color: rgba(255,255,255,0.32); font-weight: 600; }
.lc-score-sep { display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 0 12rpx; }
.lc-colon { font-size: 68rpx; font-weight: 900; color: rgba(166,255,51,0.55); line-height: 1; }
.lc-set-badge {
  font-size: 18rpx; color: rgba(166,255,51,0.7);
  background: rgba(166,255,51,0.08); border-radius: 100rpx; padding: 4rpx 14rpx;
}
.lc-timeline {
  margin: 24rpx 36rpx 0; background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.07); border-radius: 24rpx; padding: 20rpx 24rpx;
}
.lc-tl-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.lc-tl-label { font-size: 20rpx; font-weight: 700; color: rgba(255,255,255,0.35); letter-spacing: 2rpx; }
.lc-tl-count { font-size: 18rpx; color: rgba(255,255,255,0.22); }
.lc-tl-empty { padding: 12rpx 0; }
.lc-tl-empty-txt { font-size: 22rpx; color: rgba(255,255,255,0.22); }
.lc-tl-item { display: flex; gap: 16rpx; }
.lc-tl-item:not(:last-child) { margin-bottom: 16rpx; }
.lc-tl-left { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; width: 22rpx; }
.lc-tl-dot { width: 18rpx; height: 18rpx; border-radius: 50%; flex-shrink: 0; margin-top: 6rpx; }
.dot-photo { background: #A6FF33; }
.dot-text { background: rgba(255,255,255,0.28); }
.dot-score { background: #4ECDC4; }
.lc-tl-line { flex: 1; width: 2rpx; background: rgba(255,255,255,0.07); margin-top: 6rpx; min-height: 24rpx; }
.lc-tl-body { flex: 1; min-width: 0; }
.lc-tl-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 6rpx; }
.lc-tl-emoji { font-size: 20rpx; }
.lc-tl-author { font-size: 20rpx; font-weight: 700; color: rgba(255,255,255,0.65); flex: 1; }
.lc-tl-ago { font-size: 18rpx; color: rgba(255,255,255,0.25); }
.lc-tl-text { display: block; font-size: 24rpx; color: rgba(255,255,255,0.75); line-height: 1.5; }
.lc-tl-thumb { width: 120rpx; height: 90rpx; border-radius: 12rpx; margin-top: 10rpx; display: block; }
.lc-actions { display: flex; gap: 16rpx; padding: 20rpx 36rpx 28rpx; margin-top: 20rpx; }
.lc-action-btn {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 10rpx;
  padding: 22rpx 0; border-radius: 22rpx; font-size: 24rpx; font-weight: 700;
}
.lc-action-icon { font-size: 28rpx; }
.lc-action-txt { font-size: 24rpx; font-weight: 700; }
.lc-action-photo { background: rgba(166,255,51,0.14); border: 1.5rpx solid rgba(166,255,51,0.35); color: #A6FF33; }
.lc-action-score { background: rgba(255,255,255,0.07); border: 1.5rpx solid rgba(255,255,255,0.14); color: rgba(255,255,255,0.75); }

/* Load More */
.load-footer { text-align: center; padding: 32rpx 0 16rpx; }
.load-more-row { display: flex; align-items: center; justify-content: center; gap: 12rpx; }
.load-spin {
  width: 32rpx; height: 32rpx;
  border: 3rpx solid rgba(43,182,115,0.2); border-top-color: #2BB673;
  border-radius: 50%; animation: spin-sm 0.8s linear infinite;
}
.load-more-txt { font-size: 24rpx; color: rgba(255,255,255,0.35); }
.create-card {
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(135deg, #0E231A 0%, #1A3D2B 100%);
  border-radius: 28rpx; padding: 32rpx 36rpx;
}
.create-card-left { flex: 1; }
.create-card-title { display: block; font-size: 28rpx; font-weight: 700; color: #FFFFFF; margin-bottom: 8rpx; }
.create-card-sub { display: block; font-size: 22rpx; color: rgba(255,255,255,0.5); }
.create-card-btn {
  flex-shrink: 0; background: #A6FF33; color: #0E231A;
  font-size: 24rpx; font-weight: 800; padding: 16rpx 28rpx;
  border-radius: 100rpx; margin-left: 24rpx;
}

/* Score Overlay */
.score-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.65);
  display: flex; align-items: flex-end; z-index: 500;
}
.score-sheet {
  width: 100%; background: #142B1C;
  border-radius: 40rpx 40rpx 0 0;
  padding: 20rpx 40rpx calc(60rpx + env(safe-area-inset-bottom));
}
.ss-handle { width: 80rpx; height: 6rpx; background: rgba(255,255,255,0.18); border-radius: 100rpx; margin: 0 auto 32rpx; }
.ss-title { font-size: 32rpx; font-weight: 800; color: #FFFFFF; text-align: center; margin-bottom: 40rpx; }
.ss-score-row { display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 32rpx; }
.ss-side { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.ss-side-label { font-size: 20rpx; color: rgba(255,255,255,0.38); font-weight: 600; letter-spacing: 2rpx; }
.ss-ctrl { display: flex; align-items: center; gap: 24rpx; }
.ss-sub, .ss-add { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40rpx; font-weight: 700; }
.ss-sub { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.55); }
.ss-add { background: rgba(166,255,51,0.15); color: #A6FF33; border: 1rpx solid rgba(166,255,51,0.35); }
.ss-num { font-size: 80rpx; font-weight: 900; color: #FFFFFF; line-height: 1; min-width: 60rpx; text-align: center; }
.ss-colon { font-size: 64rpx; font-weight: 900; color: rgba(166,255,51,0.5); padding: 0 8rpx 16rpx; }
.ss-set-row { display: flex; align-items: center; justify-content: center; gap: 24rpx; margin-bottom: 36rpx; padding-top: 24rpx; border-top: 1rpx solid rgba(255,255,255,0.07); }
.ss-set-txt { font-size: 24rpx; color: rgba(255,255,255,0.45); }
.ss-set-next { font-size: 22rpx; color: rgba(166,255,51,0.75); border: 1rpx solid rgba(166,255,51,0.3); border-radius: 100rpx; padding: 10rpx 22rpx; }
.ss-confirm { background: #A6FF33; color: #0B1A10; font-size: 30rpx; font-weight: 800; text-align: center; padding: 30rpx 0; border-radius: 24rpx; }
