<scroll-view class="page" scroll-y>

  <!-- ══ 顶部状态区 ══ -->
  <view class="header">
    <view class="header-glow"></view>
    <view class="header-label">AI 教练</view>

    <!-- 有画像：悬浮追踪卡 -->
    <view wx:if="{{hasPortrait}}" class="track-card">
      <view class="track-icon-wrap">
        <view class="track-ring"></view>
        <text class="track-ball">🎾</text>
      </view>
      <view class="track-info">
        <text class="track-label">当前训练追踪</text>
        <text class="track-val">{{todayFocus}}</text>
      </view>
    </view>

    <!-- 无画像：引导建档 -->
    <view wx:else class="header-cta" bindtap="goSetup">
      <text class="cta-txt">建立球员档案，开启 AI 成长</text>
      <text class="cta-arr">→</text>
    </view>
  </view>

  <!-- ══ Body ══ -->
  <view class="body">

    <!-- ── 核心功能入口 2 列 ── -->
    <view class="entry-row">

      <!-- AI 问答 -->
      <view class="entry-card" hover-class="entry-pressed" hover-stay-time="120" bindtap="goChat">
        <view class="entry-icon-wrap icon-green">
          <text class="entry-emoji">💬</text>
        </view>
        <text class="entry-title">AI 问答</text>
        <text class="entry-desc">随时问教练随时进步</text>
        <text class="entry-action">开始提问 →</text>
      </view>

      <!-- 动作分析（即将上线）-->
      <view class="entry-card entry-dim" hover-class="entry-pressed" hover-stay-time="120" bindtap="goPhotoAnalysis">
        <view class="entry-icon-wrap icon-teal">
          <text class="entry-emoji">📷</text>
          <view class="scan-line"></view>
        </view>
        <text class="entry-title">动作分析</text>
        <text class="entry-desc">上传照片 AI 解析姿势</text>
        <text class="entry-badge">即将上线</text>
      </view>

    </view>

<!-- ── 快速提问 2 列 Grid ── -->
    <view class="quick-section">
      <view class="section-hd">
        <text class="section-title">快速提问</text>
        <view class="refresh-btn" hover-class="refresh-pressed" hover-stay-time="100" bindtap="refreshQuestions">
          <text class="refresh-icon">↻</text>
          <text class="refresh-txt">换一换</text>
        </view>
      </view>
      <view class="quick-grid">
        <view wx:for="{{visibleQuestions}}" wx:key="*this" wx:for-item="q"
              class="quick-btn" hover-class="quick-pressed" hover-stay-time="120"
              bindtap="goChatWithQuestion" data-q="{{q}}">
          {{q}}
        </view>
      </view>
    </view>

    <!-- ── 最近提问 ── -->
    <view class="recent-section" wx:if="{{recentChats.length > 0}}">
      <view class="section-hd">
        <text class="section-title">最近提问</text>
      </view>
      <view wx:for="{{recentChats}}" wx:key="q" wx:for-item="c"
            class="recent-item" hover-class="recent-pressed" hover-stay-time="120"
            bindtap="goChatReview" data-q="{{c.q}}">
        <text class="recent-q">{{c.q}}</text>
        <text class="recent-arr">›</text>
      </view>
    </view>

    <view style="height: 60rpx;"></view>
  </view>

</scroll-view>
