/* ══ 新拟态阴影变量 ══
   背景基色: #0E231A
   光亮侧: rgba(26, 62, 40, 0.7)  — 偏亮的深绿
   暗影侧: rgba(4,  9,  6, 0.95) — 近黑
*/

.page { background: #0E231A; min-height: 100vh; }

/* ══ 顶部状态区 ══ */
.header {
  background: linear-gradient(160deg, #071410 0%, #0A1D14 55%, #071410 100%);
  padding: 52rpx 36rpx 44rpx;
  position: relative;
  overflow: hidden;
}
.header-glow {
  position: absolute;
  width: 560rpx; height: 560rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(166,255,51,0.12) 0%, transparent 65%);
  top: -220rpx; right: -120rpx;
  pointer-events: none;
}
.header-label {
  font-size: 24rpx; font-weight: 600;
  color: rgba(255,255,255,0.35); letter-spacing: 3rpx;
  margin-bottom: 24rpx;
}

/* 悬浮追踪卡 */
.track-card {
  display: flex; align-items: center; gap: 24rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.09);
  border-radius: 28rpx; padding: 24rpx 28rpx;
  box-shadow:
    0 20rpx 40rpx rgba(0,0,0,0.5),
    0 4rpx 12rpx rgba(0,0,0,0.3),
    inset 0 1rpx 0 rgba(255,255,255,0.06);
}
.track-icon-wrap {
  width: 76rpx; height: 76rpx; flex-shrink: 0;
  position: relative; display: flex; align-items: center; justify-content: center;
}
.track-ring {
  position: absolute; inset: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(166,255,51,0.55);
  animation: pulse-ring 2.2s ease-out infinite;
}
@keyframes pulse-ring {
  0%   { transform: scale(0.82); opacity: 0.9; }
  100% { transform: scale(1.38); opacity: 0; }
}
.track-ball {
  font-size: 40rpx;
  animation: bounce-ball 2s ease-in-out infinite;
  display: block;
}
@keyframes bounce-ball {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50%       { transform: translateY(-10rpx) rotate(180deg); }
}
.track-info { flex: 1; min-width: 0; }
.track-label { font-size: 22rpx; color: rgba(255,255,255,0.38); display: block; margin-bottom: 8rpx; }
.track-val   { font-size: 30rpx; font-weight: 700; color: #A6FF33; display: block; line-height: 1.4; }

/* 引导建档 */
.header-cta {
  display: flex; align-items: center; gap: 16rpx;
  background: rgba(166,255,51,0.10);
  border: 1rpx solid rgba(166,255,51,0.28);
  border-radius: 20rpx; padding: 22rpx 26rpx;
}
.cta-txt { font-size: 28rpx; color: rgba(255,255,255,0.8); flex: 1; }
.cta-arr { font-size: 32rpx; color: #A6FF33; }

/* ══ Body ══ */
.body { padding: 28rpx 28rpx 0; }

/* ── 核心功能 2 列 ── */
.entry-row {
  display: flex; gap: 20rpx;
  align-items: stretch;
  margin-bottom: 32rpx;
}
.entry-card {
  flex: 1;
  display: flex; flex-direction: column;
  background: #0E231A;
  border-radius: 28rpx; padding: 28rpx 24rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
  box-shadow:
    -8rpx -8rpx 18rpx rgba(26,62,40,0.65),
     8rpx  8rpx 22rpx rgba(4,9,6,0.95);
}
.entry-pressed {
  box-shadow:
    inset 5rpx  5rpx 12rpx rgba(4,9,6,0.9),
    inset -5rpx -5rpx 12rpx rgba(26,62,40,0.55);
}
.entry-dim { opacity: 0.72; }

/* 图标容器（内凹新拟态）*/
.entry-icon-wrap {
  width: 88rpx; height: 88rpx;
  border-radius: 22rpx;
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
  margin-bottom: 22rpx;
  box-shadow:
    inset 4rpx  4rpx 10rpx rgba(4,9,6,0.85),
    inset -4rpx -4rpx 10rpx rgba(26,62,40,0.55);
}
.icon-green { background: rgba(166,255,51,0.06); }
.icon-teal  { background: rgba(78,205,196,0.06); }
.entry-emoji { font-size: 44rpx; }

/* 动作分析扫描线 */
.scan-line {
  position: absolute; left: 0; right: 0; height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, #4ECDC4 50%, transparent 100%);
  animation: scanline 2.6s ease-in-out infinite;
}
@keyframes scanline {
  0%   { top: 0%;   opacity: 0; }
  12%  { opacity: 0.9; }
  88%  { opacity: 0.9; }
  100% { top: 100%; opacity: 0; }
}

.entry-title {
  font-size: 30rpx; font-weight: 800; color: #FFFFFF;
  display: block; margin-bottom: 8rpx;
}
.entry-desc {
  font-size: 22rpx; color: rgba(255,255,255,0.4);
  display: block; line-height: 1.5; flex: 1;
}
.entry-action {
  margin-top: 24rpx;
  font-size: 24rpx; font-weight: 700; color: #A6FF33;
  display: block;
}
.entry-badge {
  margin-top: 24rpx;
  display: inline-block;
  font-size: 20rpx; color: #4ECDC4;
  background: rgba(78,205,196,0.12);
  border-radius: 8rpx; padding: 4rpx 14rpx;
}

/* ── 本周训练计划 Timeline ── */
.plan-section { margin-bottom: 32rpx; }
.section-hd {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 24rpx; font-weight: 700;
  color: rgba(255,255,255,0.45); letter-spacing: 2rpx;
}
.section-icon { font-size: 28rpx; }

.plan-scroll { width: 100%; }
.plan-row {
  display: inline-flex; gap: 16rpx;
  padding: 8rpx 4rpx 20rpx;
}
.plan-day-card {
  flex-shrink: 0; width: 164rpx;
  background: #0E231A;
  border-radius: 22rpx; padding: 24rpx 20rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
  box-shadow:
    -6rpx -6rpx 14rpx rgba(26,62,40,0.6),
     6rpx  6rpx 18rpx rgba(4,9,6,0.95);
}
.plan-day {
  font-size: 28rpx; font-weight: 800; color: #A6FF33;
  display: block; margin-bottom: 10rpx;
}
.plan-task {
  font-size: 22rpx; color: rgba(255,255,255,0.6);
  display: block; line-height: 1.6;
}
.plan-rest .plan-day  { color: rgba(255,255,255,0.28); }
.plan-rest .plan-task { color: rgba(255,255,255,0.22); }

/* ── 快速提问 Grid ── */
.quick-section { margin-bottom: 28rpx; }

.refresh-btn {
  display: flex; align-items: center; gap: 8rpx;
  background: #0E231A;
  border-radius: 100rpx; padding: 8rpx 20rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
  box-shadow:
    -4rpx -4rpx 8rpx rgba(26,62,40,0.5),
     4rpx  4rpx 10rpx rgba(4,9,6,0.9);
}
.refresh-pressed {
  box-shadow:
    inset 3rpx  3rpx 8rpx rgba(4,9,6,0.9),
    inset -3rpx -3rpx 8rpx rgba(26,62,40,0.5);
}
.refresh-icon { font-size: 30rpx; color: #A6FF33; }
.refresh-txt  { font-size: 22rpx; color: rgba(255,255,255,0.4); }

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.quick-btn {
  background: #0E231A;
  border-radius: 20rpx; padding: 24rpx 20rpx;
  font-size: 24rpx; color: rgba(255,255,255,0.72);
  line-height: 1.6;
  border: 1rpx solid rgba(255,255,255,0.04);
  box-shadow:
    -6rpx -6rpx 14rpx rgba(26,62,40,0.6),
     6rpx  6rpx 18rpx rgba(4,9,6,0.95);
}
.quick-pressed {
  box-shadow:
    inset 4rpx  4rpx 10rpx rgba(4,9,6,0.9),
    inset -4rpx -4rpx 10rpx rgba(26,62,40,0.5);
  color: #A6FF33;
}

/* ── 最近提问 ── */
.recent-section { margin-bottom: 24rpx; }
.recent-item {
  display: flex; align-items: center; justify-content: space-between;
  background: #0E231A;
  border-radius: 20rpx; padding: 24rpx 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
  box-shadow:
    -6rpx -6rpx 14rpx rgba(26,62,40,0.6),
     6rpx  6rpx 18rpx rgba(4,9,6,0.95);
}
.recent-pressed {
  box-shadow:
    inset 4rpx  4rpx 10rpx rgba(4,9,6,0.9),
    inset -4rpx -4rpx 10rpx rgba(26,62,40,0.5);
}
.recent-q   { font-size: 26rpx; color: rgba(255,255,255,0.72); flex: 1; }
.recent-arr { font-size: 32rpx; color: rgba(255,255,255,0.25); margin-left: 16rpx; }
