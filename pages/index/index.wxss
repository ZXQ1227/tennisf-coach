/* ── Keyframes ── */
@keyframes dot-live {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.3; transform: scale(0.75); }
}

@keyframes dot-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes card-glow {
  0%, 100% { box-shadow: 0 2rpx 20rpx rgba(0,0,0,0.05); }
  50% { box-shadow: 0 0 28rpx rgba(43,182,115,0.18), 0 2rpx 20rpx rgba(0,0,0,0.05); }
}

@keyframes slide-up {
  from { opacity: 0; transform: translateY(16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Page ── */
.page {
  padding: 0 32rpx 80rpx;
  min-height: 100vh;
  background: #F7F8FA;
}

/* ── Header ── */
.header { padding: 56rpx 0 28rpx; }

.greeting { font-size: 28rpx; color: #999; margin-bottom: 10rpx; }

.question {
  font-size: 50rpx;
  font-weight: 800;
  color: #1A1A1A;
  letter-spacing: -1rpx;
  line-height: 1.2;
  margin-bottom: 18rpx;
}

/* Live Banner */
.live-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(43,182,115,0.08);
  border: 1.5rpx solid rgba(43,182,115,0.28);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 4rpx;
}

.live-banner-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2BB673;
  flex-shrink: 0;
  animation: dot-live 1.5s ease-in-out infinite;
}

.live-banner-text { font-size: 26rpx; font-weight: 600; color: #2BB673; flex: 1; }
.live-banner-arrow { font-size: 24rpx; color: rgba(43,182,115,0.65); }

.active-hint { font-size: 26rpx; color: #2BB673; font-weight: 600; }
.active-hint.empty { color: #CCC; }

/* ── Filter Bar ── */
.filter-bar {
  display: flex;
  white-space: nowrap;
  margin: 0 -32rpx 28rpx;
  padding: 0 32rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #888;
  background: #FFFFFF;
  border: 2rpx solid #EEEEEE;
  margin-right: 14rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-chip-active { background: #1A1A1A; color: #FFFFFF; border-color: #1A1A1A; }

/* ── Empty ── */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.empty-emoji { font-size: 80rpx; margin-bottom: 28rpx; }
.empty-title { font-size: 34rpx; font-weight: 600; color: #333; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #BBB; }

/* ── 普通卡片 ── */
.card {
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 20rpx rgba(0,0,0,0.05);
  border: 2rpx solid #F0F0F0;
}

.card-starting-soon { border-color: #FF6B2B; background: #FFFAF7; }
.card-dim { opacity: 0.52; }

.card-status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-dot { width: 10rpx; height: 10rpx; border-radius: 50%; flex-shrink: 0; }
.dot-live { animation: dot-live 1.5s ease-in-out infinite; }
.dot-pulse { animation: dot-pulse 1s ease-in-out infinite; }

.time-label { font-size: 24rpx; color: #AAAAAA; font-weight: 500; }
.time-label-urgent { color: #FF6B2B; font-weight: 700; }
.time-label-live { color: #2BB673; font-weight: 600; }

.card-location {
  font-size: 46rpx;
  font-weight: 800;
  color: #1A1A1A;
  margin-bottom: 16rpx;
  line-height: 1.2;
  letter-spacing: -1rpx;
}

.card-tags { display: flex; gap: 10rpx; flex-wrap: wrap; margin-bottom: 28rpx; }

.tag {
  font-size: 22rpx;
  color: #888;
  background: #F4F4F4;
  padding: 6rpx 16rpx;
  border-radius: 14rpx;
  font-weight: 500;
}

.tag-level { font-weight: 700; }

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 24rpx;
  border-top: 1rpx solid #F5F5F5;
}

.spots-wrap { display: flex; flex-direction: column; gap: 6rpx; }
.spots-main { font-size: 34rpx; font-weight: 800; color: #1A1A1A; letter-spacing: -0.5rpx; }
.spots-dim { color: #AAAAAA; }
.spots-sub { font-size: 22rpx; color: #BBBBBB; }

.cta-btn { border-radius: 100rpx; font-size: 26rpx; font-weight: 700; padding: 18rpx 32rpx; }
.cta-joined { background: #E8F9F1; color: #2BB673; border: 1.5rpx solid rgba(43,182,115,0.3); }
.cta-recruiting { background: #2BB673; color: #FFFFFF; box-shadow: 0 4rpx 16rpx rgba(43,182,115,0.35); }
.cta-soon { background: #FF6B2B; color: #FFFFFF; box-shadow: 0 4rpx 16rpx rgba(255,107,43,0.35); }
.cta-full { background: #F4F4F4; color: #888; }
.cta-disabled { background: #F4F4F4; color: #BBBBBB; }
.cta-live { background: rgba(43,182,115,0.12); color: #2BB673; border: 1rpx solid rgba(43,182,115,0.35); }

/* ══════════════════════════════════════
   ★  LIVE CARD  ★
   ══════════════════════════════════════ */
.live-card {
  background: #0E231A;
  border-radius: 40rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1.5rpx solid rgba(166,255,51,0.22);
  animation: card-glow 3s ease-in-out infinite;
  animation: slide-up 0.3s ease-out;
}

/* 顶部状态 + 时长 */
.lc-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 36rpx 0;
}

.lc-status-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(166,255,51,0.12);
  border: 1rpx solid rgba(166,255,51,0.3);
  border-radius: 100rpx;
  padding: 10rpx 22rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #A6FF33;
}

.lc-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #A6FF33;
  animation: dot-live 1.5s ease-in-out infinite;
}

.lc-elapsed { font-size: 24rpx; color: rgba(255,255,255,0.45); font-weight: 500; }
.lc-sub-badge { font-size: 20rpx; font-weight: 600; }

/* 场地名 */
.lc-venue {
  font-size: 52rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: -1rpx;
  line-height: 1.2;
  padding: 18rpx 36rpx 0;
}

/* 标签 + 人数 */
.lc-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 36rpx 0;
}

.lc-tags { display: flex; gap: 10rpx; }

.lc-tag {
  font-size: 20rpx;
  color: rgba(255,255,255,0.45);
  background: rgba(255,255,255,0.07);
  border-radius: 12rpx;
  padding: 5rpx 14rpx;
}

.lc-players { font-size: 22rpx; color: rgba(255,255,255,0.35); }

/* 比分行 */
.lc-score-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 36rpx 0;
  gap: 0;
}

.lc-score-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.lc-score-num {
  font-size: 88rpx;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -3rpx;
}

.lc-score-a { color: #FFFFFF; }
.lc-score-b { color: rgba(255,255,255,0.45); }

.lc-score-name { font-size: 20rpx; color: rgba(255,255,255,0.32); font-weight: 600; }

.lc-score-sep {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 0 12rpx;
}

.lc-colon {
  font-size: 68rpx;
  font-weight: 900;
  color: rgba(166,255,51,0.55);
  line-height: 1;
}

.lc-set-badge {
  font-size: 18rpx;
  color: rgba(166,255,51,0.7);
  background: rgba(166,255,51,0.08);
  border-radius: 100rpx;
  padding: 4rpx 14rpx;
  white-space: nowrap;
}

/* ── Timeline ── */
.lc-timeline {
  margin: 24rpx 36rpx 0;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.07);
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
}

.lc-tl-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.lc-tl-label {
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.35);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.lc-tl-count { font-size: 18rpx; color: rgba(255,255,255,0.22); }

.lc-tl-empty { padding: 12rpx 0; }
.lc-tl-empty-txt { font-size: 22rpx; color: rgba(255,255,255,0.22); }

/* Timeline 条目 */
.lc-tl-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 0;
}

.lc-tl-item:not(:last-child) { margin-bottom: 16rpx; }

.lc-tl-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 22rpx;
}

.lc-tl-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.dot-photo { background: #A6FF33; }
.dot-text { background: rgba(255,255,255,0.28); }
.dot-score { background: #4ECDC4; }

.lc-tl-line {
  flex: 1;
  width: 2rpx;
  background: rgba(255,255,255,0.07);
  margin-top: 6rpx;
  min-height: 24rpx;
}

.lc-tl-body { flex: 1; min-width: 0; }

.lc-tl-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.lc-tl-emoji { font-size: 20rpx; }
.lc-tl-author { font-size: 20rpx; font-weight: 700; color: rgba(255,255,255,0.65); flex: 1; }
.lc-tl-ago { font-size: 18rpx; color: rgba(255,255,255,0.25); }

.lc-tl-text {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1.5;
}

.lc-tl-thumb {
  width: 120rpx;
  height: 90rpx;
  border-radius: 12rpx;
  margin-top: 10rpx;
  display: block;
}

/* ── Action Buttons ── */
.lc-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 36rpx 28rpx;
  margin-top: 20rpx;
}

.lc-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx 0;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.lc-action-icon { font-size: 28rpx; }
.lc-action-txt { font-size: 24rpx; font-weight: 700; }

.lc-action-photo {
  background: rgba(166,255,51,0.14);
  border: 1.5rpx solid rgba(166,255,51,0.35);
  color: #A6FF33;
}

.lc-action-score {
  background: rgba(255,255,255,0.07);
  border: 1.5rpx solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.75);
}

/* ══════════════════════════════════════
   ★  SCORE OVERLAY  ★
   ══════════════════════════════════════ */
.score-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.65);
  display: flex;
  align-items: flex-end;
  z-index: 500;
}

.score-sheet {
  width: 100%;
  background: #142B1C;
  border-radius: 40rpx 40rpx 0 0;
  padding: 20rpx 40rpx 60rpx;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

.ss-handle {
  width: 80rpx;
  height: 6rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 100rpx;
  margin: 0 auto 32rpx;
}

.ss-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-align: center;
  margin-bottom: 40rpx;
}

.ss-score-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-bottom: 32rpx;
}

.ss-side {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.ss-side-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.38);
  font-weight: 600;
  letter-spacing: 2rpx;
}

.ss-ctrl {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.ss-sub, .ss-add {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
}

.ss-sub { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.55); }
.ss-add { background: rgba(166,255,51,0.15); color: #A6FF33; border: 1rpx solid rgba(166,255,51,0.35); }

.ss-num {
  font-size: 80rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1;
  min-width: 60rpx;
  text-align: center;
}

.ss-colon {
  font-size: 64rpx;
  font-weight: 900;
  color: rgba(166,255,51,0.5);
  padding: 0 8rpx;
  padding-bottom: 16rpx;
}

.ss-set-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 36rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255,255,255,0.07);
}

.ss-set-txt { font-size: 24rpx; color: rgba(255,255,255,0.45); }

.ss-set-next {
  font-size: 22rpx;
  color: rgba(166,255,51,0.75);
  border: 1rpx solid rgba(166,255,51,0.3);
  border-radius: 100rpx;
  padding: 10rpx 22rpx;
}

.ss-confirm {
  background: #A6FF33;
  color: #0B1A10;
  font-size: 30rpx;
  font-weight: 800;
  text-align: center;
  padding: 30rpx 0;
  border-radius: 24rpx;
}

/* ── Load More Footer ── */
.load-footer {
  text-align: center;
  padding: 32rpx 0 48rpx;
}

.load-more-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.load-spin {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(43,182,115,0.2);
  border-top-color: #2BB673;
  border-radius: 50%;
  animation: spin-sm 0.8s linear infinite;
}

@keyframes spin-sm { to { transform: rotate(360deg) } }

.load-more-txt {
  font-size: 24rpx;
  color: rgba(0,0,0,0.35);
}

.no-more-txt {
  font-size: 22rpx;
  color: rgba(0,0,0,0.25);
  letter-spacing: 2rpx;
}
