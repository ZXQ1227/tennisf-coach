<view class="page">

  <!-- ══ 自定义导航栏（刘海屏/灵动岛适配）══ -->
  <view class="nav-bar" style="padding-top:{{statusBarHeight}}px">
    <view class="nav-inner">
      <view class="nav-back" bindtap="onBack">
        <text class="nav-back-icon">‹</text>
      </view>
      <view class="nav-center">
        <text class="nav-title">AI 教练</text>
        <view class="status-dot {{sending ? 'dot-busy' : 'dot-online'}}"></view>
      </view>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- ══ 对话消息流 ══ -->
  <scroll-view class="msg-list" scroll-y scroll-into-view="{{scrollId}}" scroll-with-animation>

    <view wx:for="{{messages}}" wx:key="id" wx:for-item="msg"
          class="msg-row {{msg.role === 'user' ? 'row-user' : 'row-ai'}}"
          id="{{msg.id}}">

      <!-- AI 头像 -->
      <view wx:if="{{msg.role === 'assistant'}}" class="ai-av">
        <text class="ai-av-icon">🎾</text>
      </view>

      <!-- 气泡 -->
      <view class="bubble {{msg.role === 'user' ? 'bub-user' : 'bub-ai'}}">

        <!-- 思考动画 -->
        <view wx:if="{{msg.thinking}}" class="thinking-dots">
          <view class="dot"></view>
          <view class="dot dot2"></view>
          <view class="dot dot3"></view>
        </view>

        <!-- AI 结构化内容 -->
        <block wx:elif="{{msg.role === 'assistant'}}">
          <block wx:if="{{msg.segs && msg.segs.length}}">
            <block wx:for="{{msg.segs}}" wx:key="idx" wx:for-index="idx" wx:for-item="seg">

              <!-- 普通段落文本 -->
              <text wx:if="{{seg.type === 'text'}}" class="seg-text">{{seg.text}}</text>

              <!-- 编号列表（数字加粗高亮）-->
              <view wx:elif="{{seg.type === 'numbered'}}" class="seg-ol">
                <view wx:for="{{seg.items}}" wx:key="n" wx:for-item="ni" class="ol-item">
                  <text class="ol-num">{{ni.n}}.</text>
                  <text class="ol-text">{{ni.t}}</text>
                </view>
              </view>

              <!-- 无序列表 -->
              <view wx:elif="{{seg.type === 'bullet'}}" class="seg-ul">
                <view wx:for="{{seg.items}}" wx:key="*this" wx:for-item="bi" class="ul-item">
                  <text class="ul-dot">·</text>
                  <text class="ul-text">{{bi}}</text>
                </view>
              </view>

              <!-- 训练计划卡片（含数量的条目，如"5组"）-->
              <view wx:elif="{{seg.type === 'training'}}" class="seg-train">
                <view class="train-hd">
                  <text class="train-icon">📋</text>
                  <text class="train-label">训练方案</text>
                </view>
                <view wx:for="{{seg.items}}" wx:key="*this" wx:for-item="ti" class="train-item">
                  <text class="train-arrow">▸</text>
                  <text class="train-text">{{ti}}</text>
                </view>
              </view>

            </block>
          </block>
          <!-- 无 segs 时回退到纯文本（兼容旧消息）-->
          <text wx:else class="seg-text">{{msg.content}}</text>
        </block>

        <!-- 用户气泡文字 -->
        <text wx:elif="{{msg.role === 'user'}}" class="bub-user-txt">{{msg.content}}</text>

      </view>

      <!-- 用户头像（右侧）-->
      <view wx:if="{{msg.role === 'user'}}" class="user-av">
        <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="user-av-img" mode="aspectFill" />
        <text wx:else class="user-av-ph">我</text>
      </view>

    </view>

    <!-- 初次打开：嵌入式快速提问 -->
    <view wx:if="{{showQuickStarts}}" class="qs-area">
      <text class="qs-label">试试问教练：</text>
      <view class="qs-chips">
        <view wx:for="{{quickChips}}" wx:key="label" wx:for-item="c"
              class="qs-chip" hover-class="qs-chip-pressed" hover-stay-time="100"
              bindtap="onChipTap" data-q="{{c.q}}">
          {{c.label}}
        </view>
      </view>
    </view>

    <!-- 底部安全占位（不被固定栏遮挡）-->
    <view style="height: calc(200rpx + env(safe-area-inset-bottom));"></view>

  </scroll-view>

  <!-- ══ 悬浮快捷指令横条 ══ -->
  <view class="chips-bar">
    <scroll-view class="chips-scroll" scroll-x>
      <view class="chips-row">
        <view wx:for="{{quickChips}}" wx:key="label" wx:for-item="c"
              class="chip-pill" hover-class="chip-pill-on" hover-stay-time="100"
              bindtap="onChipTap" data-q="{{c.q}}">
          {{c.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ══ 底部输入栏 ══ -->
  <view class="input-bar">
    <!-- + 功能按钮（预留图片/语音）-->
    <view class="add-btn">
      <text class="add-icon">＋</text>
    </view>

    <!-- 胶囊输入框 -->
    <input class="input-field"
           placeholder="问教练..." placeholder-class="input-ph"
           value="{{inputText}}"
           bindinput="onInput"
           confirm-type="send" bindconfirm="onSend"
           disabled="{{sending}}"
           maxlength="200" />

    <!-- 发送按钮：有内容时亮起 -->
    <view class="send-btn {{(inputText && !sending) ? 'send-active' : ''}}"
          bindtap="onSend">
      <text class="send-icon">↑</text>
    </view>
  </view>

</view>
