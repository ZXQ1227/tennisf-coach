<wxs module="util" src="./utils.wxs"></wxs>
<view class="page">

  <!-- 隐私授权弹窗 -->
  <view wx:if="{{showPrivacy}}" class="privacy-mask">
    <view class="privacy-box">
      <text class="privacy-title">隐私保护</text>
      <text class="privacy-desc">TennisF 需要获取你的微信头像和昵称，用于完善球员档案，不用于其他用途。</text>
      <button id="setup-privacy-agree-btn" class="privacy-agree"
              open-type="agreePrivacyAuthorization"
              bindagreeprivacyauthorization="onAgreePrivacy">同意并继续</button>
      <button class="privacy-deny" bindtap="onDenyPrivacy">不同意</button>
    </view>
  </view>

  <!-- 步骤指示器（步骤1-4显示，步骤5隐藏）-->
  <view class="steps-bar" wx:if="{{step < 5}}">
    <view class="steps-inner">
      <view wx:for="{{[1,2,3,4]}}" wx:key="*this" wx:for-item="s"
            class="step-dot {{step === s ? 'step-active' : step > s ? 'step-done' : ''}}"></view>
    </view>
    <text class="steps-label">{{step}} / 4</text>
  </view>

  <!-- ══════════════════════════════
       Step 1: 关于你 / 你的水平
       ══════════════════════════════ -->
  <view wx:if="{{step === 1}}" class="step-view">
    <view class="step-hd">
      <view class="step-emoji">{{isEdit ? '👤' : '🎯'}}</view>
      <view class="step-title">{{isEdit ? '关于你' : '你的水平'}}</view>
      <view class="step-sub">{{isEdit ? '更新你的球员信息' : '选择最接近你的 NTRP 等级'}}</view>
    </view>

    <!-- 头像（仅编辑模式） -->
    <view class="avatar-wrap" wx:if="{{isEdit}}">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{tempAvatarUrl || avatarUrl}}" src="{{tempAvatarUrl || avatarUrl}}"
               class="avatar-img" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-icon">📷</text>
        </view>
      </button>
      <text class="avatar-hint">点击更换头像</text>
    </view>

    <!-- 昵称（仅编辑模式） -->
    <view class="field-group" wx:if="{{isEdit}}">
      <view class="field-label">球员昵称</view>
      <input type="nickname" class="field-input" placeholder="你在 TennisF 的名字"
             value="{{nickname}}" bindinput="onNicknameInput" />
    </view>

    <!-- NTRP 水平 -->
    <view class="field-group">
      <view class="field-label">NTRP 自评水平</view>
      <view class="ntrp-grid">
        <view wx:for="{{ntrpOptions}}" wx:key="value" wx:for-item="n"
              class="ntrp-card {{ntrpLevel === n.value ? 'ntrp-active' : ''}}"
              bindtap="selectNtrp" data-value="{{n.value}}">
          <text class="ntrp-val">{{n.label}}</text>
          <text class="ntrp-desc">{{n.desc}}</text>
        </view>
      </view>
      <view class="ntrp-hint">本系统基于 USTA NTRP 通用等级特征设计</view>
    </view>

    <view wx:if="{{isEdit}}" class="logout-btn" bindtap="confirmLogout">退出账号</view>
  </view>

  <!-- ══════════════════════════════
       Step 2: 你的球
       ══════════════════════════════ -->
  <view wx:if="{{step === 2}}" class="step-view">
    <view class="step-hd">
      <view class="step-emoji">🎾</view>
      <view class="step-title">你的球</view>
      <view class="step-sub">填写你的实际水平</view>
    </view>

    <view class="field-group">
      <view class="field-label">底线最多能稳定对打多少拍？</view>
      <view class="pill-list">
        <view wx:for="{{rallyOptions}}" wx:key="*this" wx:for-item="r"
              class="pill {{rallyCount === r ? 'pill-active' : ''}}"
              bindtap="selectRally" data-value="{{r}}">{{r}}</view>
      </view>
    </view>

    <view class="field-group">
      <view class="field-label">发球能力</view>
      <view class="pill-list">
        <view wx:for="{{serveOptions}}" wx:key="*this" wx:for-item="s"
              class="pill {{serveAbility === s ? 'pill-active' : ''}}"
              bindtap="selectServe" data-value="{{s}}">{{s}}</view>
      </view>
    </view>

    <view class="field-group">
      <view class="field-label">你最稳定的技术 <text class="field-hint">可多选</text></view>
      <view class="chip-wrap">
        <view wx:for="{{strengthOptions}}" wx:key="*this" wx:for-item="s"
              class="chip {{util.contains(strengths, s) ? 'chip-active' : ''}}"
              bindtap="toggleStrength" data-value="{{s}}">{{s}}</view>
      </view>
    </view>
  </view>

  <!-- ══════════════════════════════
       Step 3: 突破口
       ══════════════════════════════ -->
  <view wx:if="{{step === 3}}" class="step-view">
    <view class="step-hd">
      <view class="step-emoji">🎯</view>
      <view class="step-title">突破口</view>
      <view class="step-sub">记录你的训练方向</view>
    </view>

    <view class="field-group">
      <view class="field-label">最头疼的问题 <text class="field-hint">可多选</text></view>
      <view class="chip-wrap">
        <view wx:for="{{weaknessOptions}}" wx:key="*this" wx:for-item="w"
              class="chip {{util.contains(weaknesses, w) ? 'chip-active' : ''}}"
              bindtap="toggleWeakness" data-value="{{w}}">{{w}}</view>
      </view>
    </view>

    <view class="field-group">
      <view class="field-label">最想提升什么？ <text class="field-hint">可多选</text></view>
      <view class="chip-wrap">
        <view wx:for="{{goalOptions}}" wx:key="*this" wx:for-item="g"
              class="chip {{util.contains(goals, g) ? 'chip-active' : ''}}"
              bindtap="toggleGoal" data-value="{{g}}">{{g}}</view>
      </view>
    </view>
  </view>

  <!-- ══════════════════════════════
       Step 4: 状态
       ══════════════════════════════ -->
  <view wx:if="{{step === 4}}" class="step-view">
    <view class="step-hd">
      <view class="step-emoji">💪</view>
      <view class="step-title">你的状态</view>
      <view class="step-sub">让训练计划更贴合你的状态</view>
    </view>

    <view class="field-group">
      <view class="field-label">体能状态</view>
      <view class="pill-list">
        <view wx:for="{{fitnessOptions}}" wx:key="*this" wx:for-item="f"
              class="pill {{fitnessLevel === f ? 'pill-active' : ''}}"
              bindtap="selectFitness" data-value="{{f}}">{{f}}</view>
      </view>
    </view>

    <view class="field-group">
      <view class="field-label">伤病情况</view>
      <view class="injury-toggle" bindtap="toggleHasInjury">
        <view class="toggle-icon">{{hasInjury ? '✓' : '○'}}</view>
        <text class="toggle-txt">目前有伤病需要注意</text>
      </view>
      <view class="chip-wrap" wx:if="{{hasInjury}}" style="margin-top:16rpx">
        <view wx:for="{{injuryOptions}}" wx:key="*this" wx:for-item="i"
              class="chip {{util.contains(injuries, i) ? 'chip-active' : ''}}"
              bindtap="toggleInjury" data-value="{{i}}">{{i}}</view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <view class="back-btn" bindtap="prevStep">{{step === 1 ? '取消' : '上一步'}}</view>
    <view class="next-btn" bindtap="nextStep">
      {{step === 4 ? '完成建档 →' : '下一步'}}
    </view>
  </view>

</view>
