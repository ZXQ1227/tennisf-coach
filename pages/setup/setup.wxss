.page {
  background: #0E231A;
  min-height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ── 步骤指示器 ── */
.steps-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 48rpx 36rpx 0;
}
.steps-inner { display: flex; gap: 12rpx; }
.step-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%;
  background: rgba(255,255,255,0.2);
}
.step-active { background: #A6FF33; width: 32rpx; border-radius: 6rpx; }
.step-done { background: rgba(166,255,51,0.4); }
.steps-label { font-size: 24rpx; color: rgba(255,255,255,0.35); }

/* ── Step 通用 ── */
.step-view { padding: 40rpx 36rpx 0; }

.step-hd { text-align: center; margin-bottom: 48rpx; }
.step-emoji { font-size: 64rpx; margin-bottom: 20rpx; }
.step-title { font-size: 44rpx; font-weight: 800; color: #FFFFFF; margin-bottom: 10rpx; }
.step-sub { font-size: 26rpx; color: rgba(255,255,255,0.45); }

/* ── 字段 ── */
.field-group { margin-bottom: 40rpx; }
.field-label { font-size: 26rpx; font-weight: 600; color: rgba(255,255,255,0.75); margin-bottom: 16rpx; display: flex; align-items: center; gap: 12rpx; }
.field-hint { font-size: 22rpx; color: rgba(255,255,255,0.35); font-weight: 400; }
.field-input {
  background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 20rpx; padding: 24rpx 28rpx; font-size: 30rpx; color: #FFFFFF;
  width: 100%; box-sizing: border-box;
}

/* ── 头像 ── */
.avatar-wrap { display: flex; flex-direction: column; align-items: center; margin-bottom: 40rpx; }
.avatar-btn { background: transparent; padding: 0; width: 140rpx; height: 140rpx; border-radius: 50%; overflow: hidden; }
.avatar-img { width: 140rpx; height: 140rpx; border-radius: 50%; }
.avatar-placeholder {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  background: rgba(255,255,255,0.1); border: 2rpx dashed rgba(255,255,255,0.3);
  display: flex; align-items: center; justify-content: center;
}
.avatar-icon { font-size: 52rpx; }
.avatar-hint { font-size: 24rpx; color: rgba(255,255,255,0.4); margin-top: 12rpx; }

/* ── NTRP 网格 ── */
.ntrp-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; }
.ntrp-card {
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 20rpx; padding: 20rpx 0; text-align: center;
}
.ntrp-active { background: rgba(166,255,51,0.12); border-color: #A6FF33; }
.ntrp-val { font-size: 32rpx; font-weight: 800; color: #FFFFFF; display: block; }
.ntrp-desc { font-size: 20rpx; color: rgba(255,255,255,0.45); display: block; margin-top: 4rpx; }
.ntrp-active .ntrp-val { color: #A6FF33; }

/* ── Pill (单选) ── */
.pill-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.pill {
  padding: 16rpx 28rpx; border-radius: 100rpx; font-size: 26rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.7);
}
.pill-active { background: rgba(166,255,51,0.15); border-color: #A6FF33; color: #A6FF33; }

/* ── Chip (多选) ── */
.chip-wrap { display: flex; flex-wrap: wrap; gap: 16rpx; }
.chip {
  padding: 16rpx 28rpx; border-radius: 100rpx; font-size: 26rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.7);
}
.chip-active { background: rgba(43,182,115,0.2); border-color: #2BB673; color: #2BB673; }

/* ── 伤病 toggle ── */
.injury-toggle { display: flex; align-items: center; gap: 16rpx; }
.toggle-icon {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: #A6FF33;
}
.toggle-txt { font-size: 26rpx; color: rgba(255,255,255,0.7); }

/* ── Step 5: 生成中 ── */
.step5 { padding: 0; }
.generating-view {
  min-height: 100vh; display: flex; flex-direction: column;
  align-items: center; justify-content: center; padding: 60rpx 40rpx;
}
.gen-ball { font-size: 80rpx; animation: spin 2s linear infinite; margin-bottom: 40rpx; }
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
.gen-title { font-size: 32rpx; color: #FFFFFF; font-weight: 700; margin-bottom: 32rpx; }
.gen-dots { display: flex; gap: 12rpx; margin-bottom: 48rpx; }
.g-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #A6FF33; animation: gblink 1.2s infinite; }
.g-dot2 { animation-delay: 0.2s; }
.g-dot3 { animation-delay: 0.4s; }
@keyframes gblink { 0%,80%,100%{ opacity:0.3; } 40%{ opacity:1; } }
.gen-tips { display: flex; flex-direction: column; gap: 16rpx; text-align: center; }
.gen-tip { font-size: 24rpx; color: rgba(255,255,255,0.4); }

/* ── Step 5: 错误 ── */
.error-view { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60rpx; }
.error-icon { font-size: 72rpx; margin-bottom: 24rpx; }
.error-txt { font-size: 28rpx; color: rgba(255,255,255,0.6); text-align: center; margin-bottom: 40rpx; }
.retry-btn {
  background: rgba(166,255,51,0.15); border: 1rpx solid #A6FF33; border-radius: 100rpx;
  padding: 20rpx 60rpx; font-size: 28rpx; color: #A6FF33; font-weight: 600;
}

/* ── Step 5: 画像结果 ── */
.portrait-view {
  min-height: 100vh; padding: 48rpx 36rpx 60rpx;
  display: flex; flex-direction: column; align-items: center; position: relative; overflow: hidden;
}
.portrait-glow {
  position: absolute; width: 600rpx; height: 600rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(166,255,51,0.12) 0%, transparent 70%);
  top: -200rpx; left: 50%; transform: translateX(-50%);
}
.portrait-avatar-wrap { position: relative; margin-bottom: 20rpx; }
.portrait-avatar-img { width: 120rpx; height: 120rpx; border-radius: 50%; border: 3rpx solid #A6FF33; }
.portrait-avatar-ph {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(166,255,51,0.15); border: 3rpx solid #A6FF33;
  display: flex; align-items: center; justify-content: center; font-size: 56rpx;
}
.portrait-name { font-size: 36rpx; font-weight: 800; color: #FFFFFF; margin-bottom: 12rpx; }
.portrait-personality {
  font-size: 28rpx; color: #A6FF33; font-weight: 700;
  background: rgba(166,255,51,0.12); border: 1rpx solid rgba(166,255,51,0.3);
  border-radius: 100rpx; padding: 10rpx 28rpx; margin-bottom: 10rpx;
}
.portrait-stage { font-size: 24rpx; color: rgba(255,255,255,0.45); margin-bottom: 32rpx; }

.portrait-note {
  background: rgba(255,255,255,0.06); border-radius: 24rpx; padding: 24rpx 28rpx;
  display: flex; gap: 16rpx; align-items: flex-start; margin-bottom: 28rpx; width: 100%; box-sizing: border-box;
}
.portrait-note-icon { font-size: 28rpx; flex-shrink: 0; margin-top: 2rpx; }
.portrait-note-txt { font-size: 26rpx; color: rgba(255,255,255,0.75); line-height: 1.7; flex: 1; }

/* 技术评分 */
.scores-card {
  background: rgba(255,255,255,0.05); border-radius: 24rpx; padding: 28rpx;
  width: 100%; box-sizing: border-box; margin-bottom: 24rpx;
}
.scores-title { font-size: 24rpx; color: rgba(255,255,255,0.45); margin-bottom: 20rpx; letter-spacing: 1rpx; }
.score-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.score-name { font-size: 24rpx; color: rgba(255,255,255,0.6); width: 56rpx; flex-shrink: 0; }
.score-bar-wrap { flex: 1; height: 8rpx; background: rgba(255,255,255,0.1); border-radius: 4rpx; overflow: hidden; }
.score-bar { height: 100%; background: linear-gradient(90deg, #2BB673, #A6FF33); border-radius: 4rpx; }
.score-num { font-size: 24rpx; color: rgba(255,255,255,0.5); width: 48rpx; text-align: right; flex-shrink: 0; }

/* 训练重点 */
.focus-card {
  background: rgba(166,255,51,0.10); border: 1rpx solid rgba(166,255,51,0.25);
  border-radius: 24rpx; padding: 24rpx 28rpx;
  width: 100%; box-sizing: border-box; margin-bottom: 48rpx;
  display: flex; flex-direction: column; gap: 8rpx;
}
.focus-label { font-size: 22rpx; color: rgba(166,255,51,0.6); }
.focus-val { font-size: 30rpx; color: #A6FF33; font-weight: 700; }

.finish-btn {
  background: #A6FF33; color: #0E231A; font-size: 32rpx; font-weight: 800;
  border-radius: 100rpx; padding: 28rpx 80rpx; letter-spacing: 1rpx;
}

/* ── 底部按钮 ── */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; gap: 20rpx; align-items: center;
  padding: 24rpx 36rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(14,35,26,0.96);
  border-top: 1rpx solid rgba(255,255,255,0.08);
  backdrop-filter: blur(12px);
}
.back-btn {
  flex: 1; text-align: center; padding: 28rpx;
  font-size: 28rpx; color: rgba(255,255,255,0.4);
  background: rgba(255,255,255,0.06); border-radius: 20rpx;
}
.next-btn {
  flex: 2; text-align: center; padding: 28rpx;
  font-size: 30rpx; font-weight: 700; color: #0E231A;
  background: #A6FF33; border-radius: 20rpx;
}
