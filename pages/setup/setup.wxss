.page {
  background: #F7F8FA;
  min-height: 100vh;
}

/* ── Hero ── */
.hero-bg {
  background: linear-gradient(145deg, #071410 0%, #0E2319 55%, #071410 100%);
  padding: 48rpx 40rpx 60rpx;
  position: relative;
  overflow: hidden;
}

.court-v {
  position: absolute;
  top: 0; bottom: 0; left: 50%;
  width: 1rpx;
  background: rgba(255,255,255,0.05);
}

.court-h {
  position: absolute;
  top: 50%; left: 10%; right: 10%;
  height: 1rpx;
  background: rgba(255,255,255,0.05);
}

.hero-glow {
  position: absolute;
  width: 400rpx; height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(43,182,115,0.2) 0%, transparent 70%);
  top: -100rpx; right: -60rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  position: relative;
  margin-bottom: 10rpx;
  letter-spacing: -1rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  position: relative;
  margin-bottom: 48rpx;
}

/* ── 头像 ── */
.avatar-section {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  background: rgba(255,255,255,0.12);
  border: 4rpx solid rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.avatar-icon { font-size: 44rpx; }

.avatar-hint {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
}

.avatar-tip {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
  margin-top: 16rpx;
  position: relative;
}

/* ── Body ── */
.body { padding: 32rpx 28rpx 80rpx; }

.section { margin-bottom: 36rpx; }

.section-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #AAAAAA;
  letter-spacing: 1rpx;
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.optional-label { font-size: 20rpx; color: #CCC; font-weight: 400; }

.input-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  border: 1rpx solid #F0F0F0;
}

.input-prefix { font-size: 32rpx; margin-right: 14rpx; }

.input {
  flex: 1;
  font-size: 30rpx;
  color: #1A1A1A;
  height: 44rpx;
}

.input-tip {
  font-size: 22rpx;
  color: #CCC;
  margin-top: 10rpx;
  padding: 0 4rpx;
}

/* ── Level cards ── */
.level-cards { display: flex; gap: 16rpx; }

.level-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  border: 2rpx solid transparent;
}

.level-card-active {
  border-color: #2BB673;
  background: #E8F9F1;
}

.level-emoji { font-size: 36rpx; }

.level-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.level-range {
  font-size: 20rpx;
  color: #AAAAAA;
}

/* ── Optional toggle ── */
.optional-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid #F0F0F0;
}

.optional-toggle-text {
  font-size: 28rpx;
  color: #2BB673;
  font-weight: 500;
}

.optional-arrow { font-size: 24rpx; color: #CCC; }

/* ── Chips ── */
.chips-row { display: flex; gap: 14rpx; flex-wrap: wrap; }

.chip {
  background: #F7F8FA;
  border-radius: 100rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #888;
  border: 2rpx solid transparent;
}

.chip-active {
  background: #E8F9F1;
  color: #1A9459;
  border-color: #2BB673;
}

/* ── Style grid ── */
.style-grid { display: flex; flex-direction: column; gap: 12rpx; }

.style-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.style-card-active { border-color: #2BB673; background: #E8F9F1; }

.style-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
  white-space: nowrap;
}

.style-desc { font-size: 24rpx; color: #AAAAAA; }

/* ── Textarea ── */
.textarea-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  border: 1rpx solid #F0F0F0;
}

.textarea {
  width: 100%;
  font-size: 28rpx;
  color: #1A1A1A;
  min-height: 100rpx;
  line-height: 1.6;
}

/* ── Save ── */
.save-btn {
  width: 100%;
  background: #2BB673;
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 34rpx;
  font-weight: 700;
  height: 100rpx;
  line-height: 100rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(43,182,115,0.4);
  margin-top: 16rpx;
}

.save-btn[disabled] { background: #CCC; box-shadow: none; }
