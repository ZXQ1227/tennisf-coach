.page { background: #F2F4F7; min-height: 100vh; }

/* ── Loading / Error 状态 ── */
.loading-wrap {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 160rpx 0; gap: 24rpx;
}
.loading-ring {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  border: 6rpx solid #E5E5E5;
  border-top-color: #2BB673;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-txt { font-size: 26rpx; color: #AAAAAA; }

.state-wrap { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; gap: 20rpx; }
.state-icon { font-size: 72rpx; }
.state-txt { font-size: 26rpx; color: #AAAAAA; }

/* ── 1. HeaderCard ── */
.header-card {
  background: linear-gradient(155deg, #071410 0%, #0E231A 45%, #16392A 100%);
  padding: 72rpx 40rpx 60rpx;
  position: relative;
  overflow: hidden;
}

/* 双向光晕 */
.header-glow-tl {
  position: absolute; width: 500rpx; height: 500rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(43,182,115,0.18) 0%, transparent 68%);
  top: -180rpx; left: -100rpx;
}
.header-glow-br {
  position: absolute; width: 360rpx; height: 360rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(166,255,51,0.10) 0%, transparent 68%);
  bottom: -80rpx; right: -80rpx;
}

.header-inner {
  position: relative;
  display: flex; flex-direction: column; align-items: center; text-align: center;
}

.header-avatar-img {
  width: 128rpx; height: 128rpx; border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.25);
  box-shadow: 0 0 32rpx rgba(43,182,115,0.3);
  margin-bottom: 22rpx;
}

.header-avatar {
  width: 144rpx; height: 144rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 60rpx; font-weight: 900; color: #FFFFFF;
  border: 4rpx solid rgba(255,255,255,0.2);
  box-shadow: 0 0 48rpx rgba(43,182,115,0.28);
  margin-bottom: 24rpx;
}

.header-name {
  font-size: 52rpx; font-weight: 900; color: #FFFFFF;
  letter-spacing: -1rpx; margin-bottom: 18rpx;
}

.header-tags { display: flex; gap: 12rpx; justify-content: center; flex-wrap: wrap; margin-bottom: 20rpx; }

.header-tag {
  font-size: 22rpx; font-weight: 700;
  background: rgba(255,255,255,0.12);
  border: 1rpx solid rgba(255,255,255,0.18);
  padding: 8rpx 22rpx; border-radius: 100rpx;
  color: rgba(255,255,255,0.88);
}

.header-bio {
  font-size: 26rpx; color: rgba(255,255,255,0.55);
  line-height: 1.7; font-style: italic;
  max-width: 520rpx; margin: 0 auto;
}

.header-noprofile { font-size: 24rpx; color: rgba(255,255,255,0.3); margin-top: 8rpx; }

/* ── 通用卡片 ── */
.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  margin: 20rpx 24rpx 0;
  padding: 36rpx;
  box-shadow: 0 4rpx 28rpx rgba(0,0,0,0.06);
}

/* ── 2. StatsCard ── */
.together-row {
  display: flex; align-items: center; gap: 12rpx;
  background: #E8F9F1;
  border-radius: 18rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 28rpx;
}
.together-icon { font-size: 32rpx; }
.together-txt { font-size: 26rpx; color: #1A8A50; font-weight: 600; }
.together-num { font-size: 30rpx; font-weight: 900; color: #2BB673; }

.stats-divider { height: 1rpx; background: #F2F2F2; margin-bottom: 28rpx; }

.stats-grid { display: flex; align-items: center; margin-bottom: 28rpx; }

.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }

.stat-main { flex-direction: row; align-items: baseline; gap: 6rpx; flex-wrap: wrap; justify-content: center; }
.stat-big { font-size: 72rpx; font-weight: 900; color: #0E231A; letter-spacing: -2rpx; line-height: 1; }
.stat-unit { font-size: 24rpx; color: #888; font-weight: 600; align-self: flex-end; padding-bottom: 8rpx; }
.stat-label { font-size: 20rpx; color: #AAAAAA; width: 100%; text-align: center; }

.stat-num { font-size: 48rpx; font-weight: 900; color: #1A1A1A; letter-spacing: -1rpx; }

.stats-vline { width: 1rpx; height: 60rpx; background: #F0F0F0; flex-shrink: 0; }

.courts-row { display: flex; align-items: flex-start; gap: 12rpx; }
.courts-icon { font-size: 28rpx; padding-top: 4rpx; flex-shrink: 0; }
.courts-tags { display: flex; flex-wrap: wrap; gap: 10rpx; }
.court-tag {
  font-size: 22rpx; font-weight: 600; color: #444;
  background: #F5F6F8; border-radius: 100rpx;
  padding: 8rpx 20rpx;
}

.card-hd { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.card-ttl { font-size: 28rpx; font-weight: 700; color: #1A1A1A; }
.card-sub { font-size: 22rpx; color: #BBBBBB; }

/* ── 适合一起打 ── */
.compat-chips { display: flex; flex-wrap: wrap; gap: 14rpx; }
.compat-chip {
  font-size: 24rpx; color: #444; font-weight: 500;
  background: #F5F6F8; border: 1rpx solid #EBEBEB;
  border-radius: 100rpx; padding: 12rpx 24rpx;
}
.compat-chip-together {
  background: #E8F9F1; border-color: rgba(43,182,115,0.3);
  color: #1A8A50; font-weight: 700;
}

/* header-tag for level */
.header-tag-lvl { border: 1rpx solid rgba(255,255,255,0.2); }

/* ── 4. FixedBottomCTA ── */
.cta-spacer { height: 160rpx; }

.cta-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #FFFFFF;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.06);
}

.cta-btn {
  width: 100%;
  background: #2BB673;
  color: #FFFFFF;
  border-radius: 100rpx;
  font-size: 32rpx;
  font-weight: 800;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  letter-spacing: 0.5rpx;
  box-shadow: 0 8rpx 32rpx rgba(43,182,115,0.45), 0 0 0 0rpx rgba(43,182,115,0);
}
