/* ══════════════════════════════════════════
   登录页 — 全屏背景图 + 品牌文案 + 底部卡片
   ══════════════════════════════════════════ */

.page {
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #091408;
}

/* ── 背景图 ── */
.bg-img {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
}

/* ── 渐变遮罩：顶深→中透→底微暗 ── */
.bg-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
  background: linear-gradient(
    to bottom,
    rgba(4, 14, 6, 0.90) 0%,
    rgba(4, 14, 6, 0.55) 28%,
    rgba(4, 14, 6, 0.08) 55%,
    rgba(4, 14, 6, 0.18) 72%,
    rgba(4, 14, 6, 0.30) 100%
  );
}

/* ── 内容层 ── */
.content {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── 返回按钮 ── */
.nav-back {
  position: fixed;
  left: 32rpx;
  z-index: 10;
  width: 72rpx; height: 72rpx;
  display: flex; align-items: center; justify-content: center;
}
.nav-back-icon { font-size: 40rpx; color: rgba(255,255,255,0.7); }

/* ── 品牌区 ── */
.brand-section {
  padding: 180rpx 48rpx 0;
}
.brand-name {
  display: block;
  font-size: 88rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: -2rpx;
  line-height: 1.05;
  margin-bottom: 20rpx;
}
.brand-tagline {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}
.tagline-plain {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
}
.tagline-accent {
  font-size: 40rpx;
  font-weight: 700;
  color: #5CE85A;
  line-height: 1.3;
}
.brand-sub {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.50);
  font-weight: 400;
}

/* ── 弹性占位 ── */
.flex-spacer {
  flex: 1;
  min-height: 100rpx;
}

/* ══════════════════════════════════════════
   底部卡片
   ══════════════════════════════════════════ */
.bottom-card {
  background: linear-gradient(
    to bottom,
    rgba(6, 18, 8, 0) 0%,
    rgba(6, 18, 8, 0.72) 12%,
    rgba(6, 18, 8, 0.96) 28%,
    rgba(6, 18, 8, 0.98) 100%
  );
  border-radius: 48rpx 48rpx 0 0;
  padding: 96rpx 48rpx;
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
}

/* ── 特性三列 ── */
.features-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 96rpx;
}
.feat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.feat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
}
.feat-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}
.feat-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  text-align: center;
}

/* ── CSS 图标：柱状图 ── */
.icon-chart {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
}
.bar {
  background: #5CE85A;
  border-radius: 4rpx 4rpx 0 0;
  width: 11rpx;
}
.b1 { height: 24rpx; }
.b2 { height: 34rpx; }
.b3 { height: 46rpx; }
.bar-dot {
  position: absolute;
  top: 0; right: 0;
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: #5CE85A;
  transform: translate(4rpx, -4rpx);
}

/* ── CSS 图标：两个人 ── */
.icon-people {
  position: relative;
  width: 64rpx;
  height: 54rpx;
}
.ph {
  position: absolute;
  width: 20rpx; height: 20rpx;
  border-radius: 50%;
  background: #5CE85A;
  top: 0;
}
.pb {
  position: absolute;
  width: 28rpx; height: 22rpx;
  border-radius: 14rpx 14rpx 0 0;
  background: #5CE85A;
  bottom: 0;
}
.ph1 { left: 4rpx; }
.pb1 { left: 0; }
.ph2 { right: 4rpx; }
.pb2 { right: 0; }

/* ── CSS 图标：奖杯 ── */
.icon-trophy {
  position: relative;
  width: 52rpx;
  height: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.trophy-cup {
  width: 44rpx; height: 34rpx;
  border-radius: 0 0 22rpx 22rpx;
  background: #5CE85A;
}
.trophy-stem {
  width: 10rpx; height: 12rpx;
  background: #5CE85A;
}
.trophy-base {
  width: 36rpx; height: 8rpx;
  border-radius: 4rpx;
  background: #5CE85A;
}

/* ── 登录按钮 ── */
.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #3FB840, #2DA832);
  border-radius: 40rpx;
  height: 112rpx;
  margin-bottom: 64rpx;
  box-shadow: 0 8rpx 32rpx rgba(60,184,64,0.35);
  border: none;
  padding: 0;
  line-height: normal;
}
.login-btn::after { display: none; }
.login-btn-placeholder { height: 112rpx; margin-bottom: 64rpx; }
.login-btn-txt {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

/* ── 微信图标（两个气泡） ── */
.wc-icon {
  position: relative;
  width: 56rpx; height: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.wc-bubble {
  position: absolute;
  border-radius: 100rpx;
  background: rgba(255,255,255,0.92);
}
.wc-main {
  width: 40rpx; height: 30rpx;
  top: 0; left: 0;
}
.wc-main::before, .wc-main::after {
  content: '';
  position: absolute;
  top: 9rpx;
  width: 7rpx; height: 7rpx;
  border-radius: 50%;
  background: rgba(47,168,50,0.9);
}
.wc-main::before { left: 8rpx; }
.wc-main::after  { left: 21rpx; }
.wc-sec {
  width: 28rpx; height: 22rpx;
  bottom: 0; right: 0;
  background: rgba(255,255,255,0.72);
}
.wc-sec::before {
  content: '';
  position: absolute;
  top: 7rpx; left: 7rpx;
  width: 5rpx; height: 5rpx;
  border-radius: 50%;
  background: rgba(47,168,50,0.8);
}

/* ── 安全提示 ── */
.privacy-row {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 56rpx;
}
.privacy-shield { font-size: 24rpx; margin-top: 2rpx; flex-shrink: 0; }
.privacy-txt {
  font-size: 22rpx;
  color: rgba(255,255,255,0.40);
  line-height: 1.7;
  text-align: center;
}


/* ══════════════════════════════════════════
   原位昵称编辑区（替换登录按钮）
   ══════════════════════════════════════════ */
.inline-nick {
  display: flex;
  align-items: center;
  gap: 20rpx;
  height: 112rpx;
  margin-bottom: 64rpx;
}
.in-av {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2rpx solid rgba(255,255,255,0.2);
}
.in-input {
  flex: 1;
  height: 92rpx;
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.18);
  border-radius: 40rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  box-sizing: border-box;
}
.in-ph { color: rgba(255,255,255,0.35); }
.in-btn {
  flex-shrink: 0;
  background: #3FB840;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 40rpx;
  padding: 0 36rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
}
.in-btn-dim { background: rgba(63,184,64,0.4); }

/* ══════════════════════════════════════════
   微信隐私授权弹窗
   ══════════════════════════════════════════ */
.privacy-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex; align-items: flex-end;
  z-index: 999;
}
.privacy-box {
  width: 100%; background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 40rpx 64rpx;
  box-sizing: border-box;
}
.privacy-title { display: block; font-size: 36rpx; font-weight: 700; color: #1A1A1A; margin-bottom: 20rpx; }
.privacy-desc { display: block; font-size: 28rpx; color: #666666; line-height: 1.6; margin-bottom: 40rpx; }
.privacy-agree {
  width: 100%; background: #2BB673; color: #FFFFFF;
  font-size: 32rpx; font-weight: 600; border-radius: 56rpx;
  padding: 32rpx 0; border: none; margin-bottom: 20rpx;
}
.privacy-agree::after { display: none; }
.privacy-deny {
  width: 100%; background: transparent; color: #AAAAAA;
  font-size: 28rpx; border: none; padding: 20rpx 0;
}
.privacy-deny::after { display: none; }
