.page {
  min-height: 100vh;
  background: #0E231A;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 60rpx;
  box-sizing: border-box;
}

/* 返回按钮 */
.nav-back {
  position: absolute; top: 88rpx; left: 40rpx;
  width: 72rpx; height: 72rpx;
  display: flex; align-items: center; justify-content: center;
}
.nav-back-icon { font-size: 40rpx; color: rgba(255,255,255,0.7); }

/* 品牌区 */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 72rpx;
}
.brand-logo { font-size: 80rpx; margin-bottom: 16rpx; }
.brand-name { font-size: 52rpx; font-weight: 800; color: #FFFFFF; letter-spacing: 2rpx; }
.brand-sub { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-top: 10rpx; }

/* 卡片 */
.card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
  margin-bottom: 48rpx;
}
.section-label {
  font-size: 26rpx;
  color: #888888;
  font-weight: 500;
  margin-bottom: 20rpx;
}

/* 头像区 */
.av-row {
  display: flex; align-items: center; gap: 24rpx;
  background: #F7F8FA; border-radius: 20rpx;
  padding: 20rpx 24rpx; margin: 0; border: none;
  width: 100%; box-sizing: border-box;
}
.av-row::after { display: none; }
.av-circle {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  overflow: hidden; flex-shrink: 0;
}
.av-img { width: 100rpx; height: 100rpx; border-radius: 50%; display: block; }
.av-ph {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: #E8F9F1;
  border: 2rpx dashed #2BB673;
  display: flex; align-items: center; justify-content: center;
}
.av-ph-icon { font-size: 40rpx; }
.av-hint { font-size: 28rpx; color: #2BB673; font-weight: 500; flex: 1; }

/* 昵称 */
.nickname-input {
  width: 100%;
  height: 96rpx;
  background: #F7F8FA;
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 34rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  border: 1.5rpx solid #EBEBEB;
}
.nickname-hint {
  display: block;
  font-size: 22rpx;
  color: #BBBBBB;
  margin-top: 12rpx;
}

/* 隐私弹窗 */
.privacy-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex; align-items: flex-end;
  z-index: 999;
}
.privacy-box {
  width: 100%; background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 40rpx 64rpx;
  box-sizing: border-box;
}
.privacy-title { display: block; font-size: 36rpx; font-weight: 700; color: #1A1A1A; margin-bottom: 20rpx; }
.privacy-desc { display: block; font-size: 28rpx; color: #666666; line-height: 1.6; margin-bottom: 40rpx; }
.privacy-agree {
  width: 100%; background: #2BB673; color: #FFFFFF;
  font-size: 32rpx; font-weight: 600; border-radius: 56rpx;
  padding: 32rpx 0; border: none; margin-bottom: 20rpx;
}
.privacy-agree::after { display: none; }
.privacy-deny {
  width: 100%; background: transparent; color: #AAAAAA;
  font-size: 28rpx; border: none; padding: 20rpx 0;
}
.privacy-deny::after { display: none; }

/* 确认按钮 */
.confirm-btn {
  width: 100%;
  background: #2BB673;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 56rpx;
  padding: 36rpx 0;
  border: none;
  letter-spacing: 1rpx;
}
.confirm-disabled {
  background: rgba(43,182,115,0.4);
}
