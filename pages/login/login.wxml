<view class="page">

  <!-- 隐私授权弹窗 -->
  <view wx:if="{{showPrivacy}}" class="privacy-mask">
    <view class="privacy-box">
      <text class="privacy-title">隐私保护</text>
      <text class="privacy-desc">TennisF 需要获取你的微信头像和昵称，用于完善球员档案，不用于其他用途。</text>
      <button id="privacy-agree-btn" class="privacy-agree"
              open-type="agreePrivacyAuthorization"
              bindagreeprivacyauthorization="onAgreePrivacy">同意并继续</button>
      <button class="privacy-deny" bindtap="onDenyPrivacy">不同意</button>
    </view>
  </view>

  <!-- 背景图 -->
  <image class="bg-img" src="/images/login-bg.jpg" mode="aspectFill" />

  <!-- 渐变遮罩：顶部深色→中间透明→底部微暗 -->
  <view class="bg-overlay" />

  <!-- 主内容层 -->
  <view class="content" style="padding-top:{{statusBarHeight}}px">

    <!-- 返回按钮 -->
    <view class="nav-back" wx:if="{{canGoBack}}" bindtap="goBack">
      <text class="nav-back-icon">←</text>
    </view>

    <!-- 品牌区 -->
    <view class="brand-section">
      <text class="brand-name">TennisF</text>
      <view class="brand-tagline">
        <text class="tagline-plain">记录每一次挥拍的</text><text class="tagline-accent">成长</text>
      </view>
      <text class="brand-sub">你的网球运动记录与成长伙伴</text>
    </view>

    <!-- 弹性占位（球的可见区） -->
    <view class="flex-spacer" />

    <!-- 底部卡片 -->
    <view class="bottom-card">

      <!-- 特性三列 -->
      <view class="features-row">
        <view class="feat-item">
          <view class="feat-icon-wrap">
            <view class="icon-chart">
              <view class="bar b1"></view>
              <view class="bar b2"></view>
              <view class="bar b3"></view>
              <view class="bar-dot"></view>
            </view>
          </view>
          <text class="feat-name">成长数据</text>
          <text class="feat-desc">记录每一场球局</text>
        </view>
        <view class="feat-item">
          <view class="feat-icon-wrap">
            <view class="icon-people">
              <view class="ph ph1"></view><view class="pb pb1"></view>
              <view class="ph ph2"></view><view class="pb pb2"></view>
            </view>
          </view>
          <text class="feat-name">球友关系</text>
          <text class="feat-desc">找到固定球搭子</text>
        </view>
        <view class="feat-item">
          <view class="feat-icon-wrap">
            <view class="icon-trophy">
              <view class="trophy-cup"></view>
              <view class="trophy-stem"></view>
              <view class="trophy-base"></view>
            </view>
          </view>
          <text class="feat-name">成就系统</text>
          <text class="feat-desc">解锁专属运动称号</text>
        </view>
      </view>

      <!-- 登录按钮：头像选完后用等高占位替换，保持卡片高度不变 -->
      <button wx:if="{{!showNickBar}}" class="login-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <view class="wc-icon">
          <view class="wc-bubble wc-main"></view>
          <view class="wc-bubble wc-sec"></view>
        </view>
        <text class="login-btn-txt">微信授权登录</text>
      </button>

      <!-- 原位昵称编辑区 -->
      <view wx:else class="inline-nick">
        <image src="{{avatarUrl}}" class="in-av" mode="aspectFill" />
        <input class="in-input" type="nickname"
               placeholder="点击选择微信昵称"
               placeholder-class="in-ph"
               value="{{nickname}}" bindinput="onNicknameInput"
               focus="{{focusNick}}" bindfocus="onNickFocus"
               bindblur="onNickBlur"
               cursor-spacing="200" />
        <view class="in-btn {{(!nickname || saving) ? 'in-btn-dim' : ''}}" bindtap="confirm">
          {{saving ? '…' : '进入'}}
        </view>
      </view>

      <!-- 安全提示 -->
      <view class="privacy-row">
        <text class="privacy-shield">🛡</text>
        <text class="privacy-txt">授权后将获取你的微信 OpenID{{"\\n"}}用于识别你的身份并保障账号安全</text>
      </view>


    </view>
  </view>


</view>
