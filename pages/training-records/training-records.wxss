.records-page {
  background: #0A1A10;
  min-height: 100vh;
}

/* ── 月份导航 ── */
.month-nav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 32rpx 8rpx;
}
.month-arrow {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(255,255,255,0.07); border: 1rpx solid rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; color: #FFFFFF; line-height: 1;
}
.month-arrow-dim { opacity: 0.3; }
.month-title { font-size: 36rpx; font-weight: 900; color: #FFFFFF; }

/* ── 日历 ── */
.calendar-wrap { padding: 0 24rpx 8rpx; }
.cal-weekdays {
  display: flex; margin-bottom: 8rpx;
}
.cal-wd {
  flex: 1; text-align: center; font-size: 20rpx; color: rgba(255,255,255,0.3);
  font-weight: 600; padding: 8rpx 0;
}
.cal-grid { display: flex; flex-wrap: wrap; }
.cal-cell {
  width: calc(100% / 7); aspect-ratio: 1;
  display: flex; align-items: center; justify-content: center;
  box-sizing: border-box;
}
.cal-cell-empty { pointer-events: none; }
.cal-day-inner {
  width: 76rpx; height: 76rpx; border-radius: 50%;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4rpx;
  position: relative;
}
.cal-day-train {
  border: 2.5rpx solid #B2FF33;
}
.cal-day-num { font-size: 26rpx; color: rgba(255,255,255,0.7); font-weight: 600; }
.cal-day-num-train { color: #B2FF33; font-weight: 900; }
.cal-cell-today .cal-day-inner { background: rgba(255,255,255,0.1); }
.cal-cell-selected .cal-day-inner { background: rgba(178,255,51,0.12); border-color: #B2FF33; }
.cal-train-dot {
  width: 8rpx; height: 8rpx; border-radius: 50%; background: #B2FF33;
}

/* ── 月统计 ── */
.month-summary {
  display: flex; align-items: center;
  margin: 8rpx 24rpx 0;
  background: #0D2015; border: 1rpx solid rgba(255,255,255,0.07);
  border-radius: 24rpx; padding: 24rpx 8rpx;
}
.msm-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.msm-val { font-size: 40rpx; font-weight: 900; color: #FFFFFF; }
.msm-lbl { font-size: 20rpx; color: rgba(255,255,255,0.4); }
.msm-divider { width: 1rpx; height: 60rpx; background: rgba(255,255,255,0.08); }

/* ── 分区 ── */
.section { margin: 28rpx 24rpx 0; }
.section-hd { margin-bottom: 16rpx; }
.section-title { font-size: 28rpx; font-weight: 800; color: rgba(255,255,255,0.9); }

/* ── 会话卡 ── */
.session-card {
  display: flex; align-items: center; justify-content: space-between;
  background: #0D2015; border: 1rpx solid rgba(255,255,255,0.07);
  border-radius: 20rpx; padding: 24rpx; margin-bottom: 12rpx;
}
.session-card-lft { display: flex; align-items: center; gap: 20rpx; flex: 1; }
.session-type-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%; background: #B2FF33; flex-shrink: 0;
}
.session-info { display: flex; flex-direction: column; gap: 6rpx; }
.session-location { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.9); }
.session-meta { font-size: 22rpx; color: rgba(255,255,255,0.4); }
.session-cancelled { font-size: 22rpx; color: rgba(255,80,80,0.7); flex-shrink: 0; }
.records-loading { display: flex; justify-content: center; padding: 80rpx 0; }
.load-spin {
  width: 48rpx; height: 48rpx; border: 4rpx solid rgba(255,255,255,0.1);
  border-top-color: #B2FF33; border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── 空状态 ── */
.empty-day {
  display: flex; align-items: center; justify-content: center;
  padding: 60rpx;
}
.empty-day-txt { font-size: 26rpx; color: rgba(255,255,255,0.25); }

/* ── 未登录状态 ── */
.not-login-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 48rpx 0;
  gap: 24rpx;
}
.not-login-icon { font-size: 80rpx; }
.not-login-txt { font-size: 30rpx; color: rgba(255,255,255,0.45); }
.not-login-btn {
  margin-top: 16rpx;
  background: #3FB840; color: #FFFFFF;
  font-size: 30rpx; font-weight: 700;
  border-radius: 48rpx;
  padding: 20rpx 72rpx;
}
